# =============================================
#  SellingTicket .gitignore
#  Keep: source code, README, docs, SQL
#  Ignore: secrets, IDE, build, AI agent files
# =============================================

# ===== SECRETS (CRITICAL - NEVER COMMIT) =====
.env
.env.*
!.env.example
SellingTicketJava/src/webapp/WEB-INF/google-oauth.properties

# ===== BUILD & COMPILED =====
SellingTicketJava/build/
SellingTicketJava/dist/
*.class
*.jar
*.war
*.ear

# ===== IDE & EDITOR =====
.idea/
.vscode/
*.iml
*.ipr
*.iws
nbproject/private/
*.sublime-*
*.suo
*.sw?

# ===== OS FILES =====
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.log

# ===== PYTHON (scripts) =====
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg

# ===== AI AGENT FILES (do not push) =====
agent/
docs
.agent
.agents/
.cursor/
.context/
.antigravity/
.github/
*.agent
*.cursorrules
agent_memory.json
mcp_servers.json
memory-bank/
artifacts/
skills-lock.json
ui-ux-pro-max-skill/
~/

# ===== DOCS: ignore generated/heavy files =====
SellingTicketJava/docs/node_modules/
SellingTicketJava/docs/package-lock.json
SellingTicketJava/docs/package.json
SellingTicketJava/docs/convert_ch6_to_docx.js
SellingTicketJava/docs/generate-usecase-docx.js
SellingTicketJava/docs/Do an Vu Duy Nguyen D19 HTTT.pdf
SellingTicketJava/docs/Project_PRJ301_ReportTemplate.docx
/SellingTicketJava/docs/diagrams/images

# ===== TEST/DEV FILES =====
