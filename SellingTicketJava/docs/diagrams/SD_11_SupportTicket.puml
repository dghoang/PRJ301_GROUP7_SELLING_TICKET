@startuml SD_11_SupportTicket
' ============================================================
' SEQUENCE DIAGRAM - Support Ticket
' FR-31~FR-32: Create + Process Support Ticket
' ============================================================

title **SD-11: Support Ticket\n(Create → Auto-route → Process → Resolve)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #E0F7FA
    ParticipantBorderColor #00838F
    ArrowColor #00838F
}

actor "Attendee" as Customer #LightBlue
participant "Browser" as Browser #LightYellow
participant "SupportServlet\n(Controller)" as Controller #E0F7FA
participant "SupportService" as Service #E8F5E9
participant "SupportTicketDAO" as DAO #FFF3E0
participant "TicketResponseDAO" as ResDAO #FFF3E0
participant "NotificationService" as NotifSvc #E0F7FA
database "SQL Server" as DB #F3E5F5
actor "Organizer /\nAdmin" as Handler #Gold

== Step 1: Create Support Ticket ==

Customer -> Browser: Click "Support"\n→ Fill out form
Browser -> Controller: POST /support/create\n{category: "missing_ticket",\nsubject, description,\neventId (optional),\norderId (optional)}
activate Controller

Controller -> Service: createTicket(ticketData)
activate Service

' --- Auto-route ---
Service -> Service: **Auto-routing logic:**\nif eventId != null AND\ncategory ∈ {missing_ticket,\ncancellation, event_issue}\n→ assignee = "organizer"\nelse → assignee = "admin"

Service -> DAO: create(SupportTicket)
activate DAO
DAO -> DB: INSERT INTO SupportTickets (\n  ticketId, ticketCode='SUP-'+random,\n  customerId, eventId, orderId,\n  category, subject, description,\n  status='open', priority='normal',\n  assigneeType, assigneeId,\n  createdAt\n)
activate DB
DB --> DAO: ticketId
deactivate DB
DAO --> Service: ticket
deactivate DAO

' --- Notify Handler ---
Service -> NotifSvc: notify(assigneeId,\n"New support ticket: {subject}",\n'NEW_SUPPORT_TICKET')
activate NotifSvc
NotifSvc -> DB: INSERT Notification
NotifSvc --> Service: OK
deactivate NotifSvc

Service --> Controller: ticket
deactivate Service
Controller --> Browser: Redirect → /support\n+ "Ticket submitted!\nCode: SUP-A1B2C3"
deactivate Controller
Browser --> Customer: ✅ Ticket created\nCode: SUP-A1B2C3\nStatus: Open

== Step 2: Handler Views & Responds ==

Handler -> Browser: Open Support Management
Browser -> Controller: GET /organizer/support\nor /admin/support
activate Controller
Controller -> Service: getTickets(handlerId,\nstatus, page)
activate Service
Service -> DAO: findByAssignee(handlerId)
activate DAO
DAO -> DB: SELECT st.*, u.fullName,\ne.title\nFROM SupportTickets st\nJOIN Users u ON st.customerId=u.userId\nLEFT JOIN Events e ON ...\nWHERE st.assigneeId = ?\nORDER BY st.status, st.priority,\nst.createdAt
activate DB
DB --> DAO: List<SupportTicket>
deactivate DB
DAO --> Service: tickets
deactivate DAO
Service --> Controller: tickets
deactivate Service
Controller --> Browser: Forward → support-list.jsp
deactivate Controller
Browser --> Handler: Support ticket list:\nID, Subject, Status, Priority

Handler -> Browser: Open ticket detail
Handler -> Browser: Type reply + Click Send
Browser -> Controller: POST /support/respond\n{ticketId, content,\nnewStatus: "in_progress"}
activate Controller
Controller -> Service: respondToTicket(\nticketId, content, status)
activate Service

Service -> ResDAO: create(response)
activate ResDAO
ResDAO -> DB: INSERT INTO TicketResponses (\n  responseId, ticketId,\n  responderId, content,\n  createdAt\n)
activate DB
DB --> ResDAO: Created
deactivate DB
ResDAO --> Service: OK
deactivate ResDAO

Service -> DAO: updateStatus(ticketId,\n"in_progress")
activate DAO
DAO -> DB: UPDATE SupportTickets SET\nstatus = 'in_progress',\nupdatedAt = GETDATE()
activate DB
DB --> DAO: Updated
deactivate DB
DAO --> Service: OK
deactivate DAO

Service -> NotifSvc: notify(customerId,\n"Your ticket has a\nnew response",\n'TICKET_RESPONSE')

Service --> Controller: OK
deactivate Service
Controller --> Browser: Redirect + flash:\n"Response sent"
deactivate Controller
Browser --> Handler: ✅ Reply sent

== Step 3: Customer Views Reply ==

Customer -> Browser: Open My Tickets
Browser -> Controller: GET /support/{ticketCode}
activate Controller
Controller -> Service: getTicketDetail(\nticketCode, customerId)
activate Service
Service --> Controller: ticket + responses
deactivate Service
Controller --> Browser: Forward → ticket-detail.jsp
deactivate Controller
Browser --> Customer: Ticket detail:\nConversation thread\nStatus: In Progress

@enduml
