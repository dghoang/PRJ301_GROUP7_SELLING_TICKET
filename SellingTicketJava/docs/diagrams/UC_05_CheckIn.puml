@startuml UC_05_CheckIn
' ============================================================
' USE CASE DIAGRAM - MODULE 5: Check-in QR Code
' QR Code Check-in Management
' ============================================================

title **Biểu đồ Use Case - Module 5\nCheck-in QR Code**

left to right direction
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #F3E5F5
    BorderColor #7B1FA2
    FontSize 12
    ArrowColor #7B1FA2
}

' === ACTORS ===
actor "Staff\n(Nhân viên)" as Staff #LightCoral
actor "Organizer\n(Nhà tổ chức)" as Organizer #Gold

' === SYSTEM BOUNDARY ===
rectangle "Module 5: Check-in QR Code" {

    usecase "**UC-5.1: Scan QR check-in**\n---\nMở camera scan QR code\ntrên vé của attendee.\nHoặc nhập ticketCode\nthủ công." as UC_SCAN

    usecase "**UC-5.2: Xác nhận check-in**\n---\nCập nhật:\nisCheckedIn = true,\ncheckedInAt = NOW(),\ncheckedInBy = staff.userId." as UC_CONFIRM

    usecase "**UC-5.3: Xem danh sách check-in**\n---\nRealtime danh sách:\nattendees đã/chưa check-in.\nFilter, search, count." as UC_LIST

    ' --- Sub use cases ---
    usecase "Decode QR Code\n(Extract ticketCode\nfrom JWT token)" as UC_DECODE <<include>>

    usecase "Validate Ticket\n(exists? correct event?\nnot checked-in?)" as UC_VALIDATE <<include>>

    usecase "Hiển thị thông tin\nattendee\n(name, ticketType)" as UC_DISPLAY <<include>>

    usecase "Manual Code Input\n(Fallback khi camera\nkhông hoạt động)" as UC_MANUAL <<extend>>

    usecase "Duplicate Check-in\nWarning\n(\"Vé đã sử dụng lúc ...\")" as UC_DUPLICATE <<extend>>
}

' === ASSOCIATIONS ===
Staff --> UC_SCAN
Staff --> UC_CONFIRM
Staff --> UC_LIST

Organizer --> UC_SCAN
Organizer --> UC_LIST

' === INCLUDE / EXTEND ===
UC_SCAN ..> UC_DECODE : <<include>>
UC_SCAN ..> UC_VALIDATE : <<include>>
UC_SCAN ..> UC_DISPLAY : <<include>>
UC_SCAN ..> UC_CONFIRM : <<include>>

UC_SCAN <.. UC_MANUAL : <<extend>>
UC_VALIDATE <.. UC_DUPLICATE : <<extend>>

' === NOTES ===
note right of UC_SCAN
  **FR-26**
  Camera-based QR scanner
  using jsQR library.
  No app download needed.
  Works on mobile browser.
end note

note right of UC_VALIDATE
  **Validation Rules:**
  1. ticketCode exists in DB
  2. Ticket belongs to this event
  3. isCheckedIn == false
  4. Order status == confirmed
end note

note bottom of UC_LIST
  **FR-28**
  Real-time stats:
  - Total attendees
  - Checked-in count
  - Remaining count
  - Check-in percentage
end note

@enduml
