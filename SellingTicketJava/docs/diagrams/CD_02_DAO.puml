' ── Abstract Base ──────────────────────────────────

abstract class "DBContext" as DBContext #F5F5F5 {
    # getConnection() : Connection
}

abstract class "BaseDAO" as BaseDAO #E8EAF6 {
    -- Functional Interfaces --
    # <<interface>> ParamSetter
    # <<interface>> RowMapper<T>
    # NO_PARAMS : ParamSetter
    -- Template Methods --
    # queryList(sql, setter, mapper) : List<T>
    # querySingle(sql, setter, mapper) : T
    # queryScalar(sql, setter, default) : int
    # queryPaged(dataSql, countSql, setter, mapper, page, size) : PageResult<T>
    # executeUpdate(sql, setter) : int
    # executeInsertReturnKey(sql, setter) : int
}

DBContext <|-- BaseDAO

