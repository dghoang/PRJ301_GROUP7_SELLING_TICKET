@startuml SD_02_Login
' ============================================================
' SEQUENCE DIAGRAM - User Login
' FR-02: Login → BCrypt Verify → Session + Remember Me
' ============================================================

title **SD-02: User Login\n(Authenticate → Session + Remember Me)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 200
skinparam sequence {
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1565C0
    ArrowColor #1565C0
}

actor "Guest" as User #LightGreen
participant "Browser\n(JSP)" as Browser #LightYellow
participant "AuthServlet\n(Controller)" as Auth #E3F2FD
participant "UserService" as Service #E8F5E9
participant "LoginAttemptTracker\n(Rate Limiter)" as Tracker #FFCCBC
participant "UserDAO" as DAO #FFF3E0
participant "RefreshTokenDAO" as TokenDAO #FFF3E0
database "SQL Server" as DB #F3E5F5

== Step 1: Open Login Page ==

User -> Browser: Click "Login"
Browser -> Auth: GET /login
activate Auth
Auth --> Browser: Forward → login.jsp\n(+ CSRF token in form)
deactivate Auth
Browser --> User: Display login form

== Step 2: Submit Credentials ==

User -> Browser: Enter email, password\n(+ optional: rememberMe ☑️)
Browser -> Auth: POST /login\n{email, password, rememberMe,\ncsrf_token}
activate Auth

== Step 3: Rate Limiting ==

Auth -> Tracker: checkAllowed(email, IP)
activate Tracker
Tracker -> Tracker: Check 2-tier lockout:\n1. email+IP: 5 fails → 15min lock\n2. IP only: 20 fails → 60min lock
Tracker --> Auth: allowed / blocked
deactivate Tracker

alt #FFE0E0 Rate Limit: Blocked
    Auth --> Browser: Forward → login.jsp\n{error: "Too many login attempts.\nPlease wait 15 minutes."}
    Browser --> User: ⚠️ Temporarily locked
else #E8F5E9 Allowed

    == Step 4: Authenticate ==

    Auth -> Service: authenticate(email, password)
    activate Service
    Service -> DAO: findByEmail(email)
    activate DAO
    DAO -> DB: SELECT * FROM Users\nWHERE email = ?\nAND isDeleted = 0
    activate DB
    DB --> DAO: User or null
    deactivate DB
    DAO --> Service: User
    deactivate DAO

    alt #FFE0E0 User Not Found
        Service --> Auth: null
        Auth -> Tracker: recordFailure(email, IP)
        Auth --> Browser: Forward → login.jsp\n{error: "Incorrect email\nor password"}
        Browser --> User: ❌ Login failed

    else #FFFDE7 Account Deactivated (isActive=false)
        Service -> Service: Check user.isActive
        Service --> Auth: throw "Account has been\ndeactivated"
        Auth --> Browser: Forward → login.jsp\n{error: "Account banned.\nContact support."}
        Browser --> User: ⛔ Account locked

    else #E8F5E9 User Found & Active

        Service -> Service: BCrypt.checkpw(\npassword, user.getPassword())

        alt #FFE0E0 Password Mismatch
            Service --> Auth: null
            Auth -> Tracker: recordFailure(email, IP)
            Auth --> Browser: Forward → login.jsp\n{error: "Incorrect email\nor password"}
            Browser --> User: ❌ Login failed
        else #E8F5E9 Password Match ✅

            Auth -> Tracker: clearAttempts(email, IP)
            Service --> Auth: User object
            deactivate Service

            ' --- Create Session ---
            Auth -> Auth: session = request.getSession(true)\nsession.setAttribute("user", user)\nsession.setAttribute("role", role)\nsession.setMaxInactiveInterval(1800)

            ' --- Remember Me ---
            opt rememberMe == true
                Auth -> Auth: token = UUID.randomUUID()
                Auth -> TokenDAO: create(RefreshToken)
                activate TokenDAO
                TokenDAO -> DB: INSERT INTO RefreshTokens\n(tokenId, userId, token,\nexpiresAt = NOW()+30days,\ncreatedAt, isRevoked=0)
                activate DB
                DB --> TokenDAO: Created
                deactivate DB
                TokenDAO --> Auth: OK
                deactivate TokenDAO
                Auth -> Browser: Set-Cookie:\nst_refresh={token};\nPath=/; HttpOnly;\nMax-Age=30days
            end

            ' --- Activity Log ---
            Auth -> DB: INSERT INTO ActivityLogs\n(action='LOGIN', userId,\nipAddress, createdAt)

            ' --- Redirect by Role ---
            Auth -> Auth: **Route by role:**\nadmin → /admin/dashboard\norganizer → /organizer/dashboard\nstaff → /staff/dashboard\ncustomer → returnUrl or /

            Auth --> Browser: Redirect → dashboard\n+ flash: "Welcome back, {name}!"
            deactivate Auth
            Browser --> User: ✅ Login successful,\nredirect to dashboard
        end
    end
end

@enduml
