@startuml SD_02_Login
' ============================================================
' SEQUENCE DIAGRAM - Đăng nhập hệ thống (User Login)
' FR-02: Đăng nhập email/password với Rate Limiting + Remember Me
' ============================================================

title **SD-02: Đăng nhập Hệ thống\n(User Login + Session Management)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1565C0
    ArrowColor #1565C0
}

actor "Guest" as User #LightGreen
participant "Browser\n(JSP)" as Browser #LightYellow
participant "AuthFilter" as AuthFilter #FFE0B2
participant "LoginServlet\n(Controller)" as Controller #E3F2FD
participant "AuthService" as AuthService #E8F5E9
participant "LoginAttemptTracker" as Tracker #FCE4EC
participant "UserDAO" as DAO #FFF3E0
participant "TokenService" as TokenSvc #E0F7FA
database "SQL Server" as DB #F3E5F5

== Hiển thị Form Login ==

User -> Browser: Truy cập /login
Browser -> Controller: GET /login
activate Controller
Controller --> Browser: Forward → login.jsp\n(form + CSRF token + rememberMe checkbox)
deactivate Controller
Browser --> User: Hiển thị form đăng nhập

== Submit Login ==

User -> Browser: Nhập email, password\n+ tick "Ghi nhớ đăng nhập"
Browser -> Controller: POST /login\n{email, password, rememberMe,\ncsrf_token}
activate Controller

' --- Rate Limiting Check ---
Controller -> Tracker: isBlocked(email, IP)
activate Tracker
Tracker -> Tracker: Check email+IP attempts\n(tier 1: email-specific)\nCheck IP-only attempts\n(tier 2: brute force scan)
alt #FFE0E0 Account Locked (Brute Force)
    Tracker --> Controller: BLOCKED\n(remaining lockout time: X min)
    Controller --> Browser: Forward → login.jsp\n+ "Tài khoản bị khóa tạm thời.\nVui lòng thử lại sau X phút."
    Browser --> User: ⛔ Hiển thị lockout message
else #E8F5E9 Not Blocked
    Tracker --> Controller: OK (not blocked)
    deactivate Tracker

    ' --- Authenticate ---
    Controller -> AuthService: authenticate(email, password)
    activate AuthService

    AuthService -> DAO: findByEmail(email)
    activate DAO
    DAO -> DB: SELECT * FROM Users\nWHERE email = ? AND isActive = 1\nAND isDeleted = 0
    activate DB
    DB --> DAO: User record or null
    deactivate DB
    DAO --> AuthService: User or null
    deactivate DAO

    alt #FFE0E0 User Not Found OR Inactive
        AuthService --> Controller: AuthenticationException\n("Email hoặc mật khẩu không đúng")
        Controller -> Tracker: recordFailedAttempt(email, IP)
        Tracker -> Tracker: Increment fail count\n(5 fails → lock 15 min email\n20 fails → lock 60 min IP)
        Controller --> Browser: Forward → login.jsp\n+ error message
        Browser --> User: ❌ Hiển thị lỗi\n(không tiết lộ email tồn tại)

    else #E8F5E9 User Found
        AuthService -> AuthService: BCrypt.checkpw(\npassword, user.hashedPassword)

        alt #FFE0E0 Password Mismatch
            AuthService --> Controller: AuthenticationException
            Controller -> Tracker: recordFailedAttempt(email, IP)
            Controller --> Browser: Forward → login.jsp\n+ error message
            Browser --> User: ❌ Hiển thị lỗi
        else #E8F5E9 Password Correct

            ' --- Clear failed attempts ---
            AuthService -> Tracker: clearAttempts(email, IP)

            ' --- Update last login ---
            AuthService -> DAO: updateLastLogin(userId)
            activate DAO
            DAO -> DB: UPDATE Users\nSET lastLogin = GETDATE()\nWHERE userId = ?
            activate DB
            DB --> DAO: Updated
            deactivate DB
            DAO --> AuthService: OK
            deactivate DAO

            AuthService --> Controller: User (authenticated)
            deactivate AuthService

            ' --- Create Session ---
            Controller -> Controller: HttpSession session = \nrequest.getSession(true)\nsession.setAttribute("user", user)\nsession.setAttribute("role", user.role)

            ' --- Remember Me Token ---
            alt rememberMe == true
                Controller -> TokenSvc: createRefreshToken(userId)
                activate TokenSvc
                TokenSvc -> DB: INSERT INTO RefreshTokens\n(tokenId, userId, token,\nexpiresAt = NOW+30 days)
                activate DB
                DB --> TokenSvc: Created
                deactivate DB
                TokenSvc --> Controller: refreshToken string
                deactivate TokenSvc
                Controller -> Controller: Set Cookie:\nst_refresh = {token}\nHttpOnly, Secure,\nSameSite=Strict,\nMax-Age=30 days
            end

            ' --- Log Activity ---
            Controller -> DB: INSERT INTO ActivityLogs\n(userId, action='LOGIN',\nipAddress, userAgent)

            ' --- Redirect by Role ---
            Controller -> Controller: Determine redirect URL\nby user.role

            alt user.role == "admin"
                Controller --> Browser: Redirect → /admin/dashboard
            else user.role == "organizer"
                Controller --> Browser: Redirect → /organizer/dashboard
            else user.role == "staff"
                Controller --> Browser: Redirect → /staff/dashboard
            else user.role == "customer"
                Controller --> Browser: Redirect → /\n(or returnUrl if exists)
            end

            Browser --> User: ✅ Dashboard theo role

        end
    end
end

deactivate Controller

@enduml
