@startuml SD_06_Checkout
' ============================================================
' SEQUENCE DIAGRAM - Checkout Flow
' FR-18~FR-21: Select Tickets → Checkout → Create Order
' ============================================================

title **SD-06: Checkout Flow\n(Select Tickets → Create Order → Payment)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #FCE4EC
    ParticipantBorderColor #C62828
    ArrowColor #C62828
}

actor "Attendee" as Customer #LightBlue
participant "Browser" as Browser #LightYellow
participant "EventDetailServlet" as EvtCtrl #FCE4EC
participant "CheckoutServlet\n(Controller)" as Controller #FCE4EC
participant "OrderService" as Service #E8F5E9
participant "VoucherService" as VoucherSvc #FFFDE7
participant "EventDAO" as EvtDAO #FFF3E0
participant "OrderDAO" as OrdDAO #FFF3E0
participant "TicketTypeDAO" as TTDAO #FFF3E0
database "SQL Server" as DB #F3E5F5

== Step 1: Select Tickets ==

Customer -> Browser: Open event page
Browser -> EvtCtrl: GET /events/{slug}
activate EvtCtrl
EvtCtrl -> EvtDAO: findBySlug(slug)
activate EvtDAO
EvtDAO -> DB: SELECT e.*, tt.*\nFROM Events e\nJOIN TicketTypes tt\nWHERE e.slug = ?\nAND e.status = 'approved'
activate DB
DB --> EvtDAO: Event + TicketTypes
deactivate DB
EvtDAO --> EvtCtrl: event
deactivate EvtDAO
EvtCtrl --> Browser: Forward → event-detail.jsp
deactivate EvtCtrl
Browser --> Customer: Event detail + Ticket Types\n(name, price, remaining qty)

Customer -> Browser: Select ticket types\n+ quantities:\n[VIP] × 2\n[Standard] × 3

== Step 2: Open Checkout ==

Browser -> Controller: POST /checkout\n{eventId, items: [\n  {ticketTypeId, qty: 2},\n  {ticketTypeId, qty: 3}\n]}
activate Controller

Controller -> Controller: Server validation:\n- User logged in?\n- Event active?\n- qty > 0?\n- qty ≤ maxTicketsPerOrder?

Controller -> TTDAO: findByIds(ticketTypeIds)
activate TTDAO
TTDAO -> DB: SELECT * FROM TicketTypes\nWHERE ticketTypeId IN (...)\nAND isActive = 1
activate DB
DB --> TTDAO: TicketTypes
deactivate DB
TTDAO --> Controller: ticketTypes
deactivate TTDAO

Controller -> Controller: **Availability Check:**\nfor each item:\nremaining = quantity - soldCount\nif qty > remaining → Error

alt #FFE0E0 Not Enough Tickets
    Controller --> Browser: Forward → event page\n+ "Only {N} VIP tickets\nremaining"
    Browser --> Customer: ❌ Not enough tickets
else #E8F5E9 Available

    Controller -> Controller: Calculate:\nVIP: 2 × 500,000 = 1,000,000\nStd: 3 × 200,000 = 600,000\n**subtotal = 1,600,000 VND**

    Controller --> Browser: Forward → checkout.jsp\n(order summary, buyer form,\nvoucher input)
    deactivate Controller
    Browser --> Customer: Checkout page:\nOrder summary,\nBuyer info form,\nVoucher code input

== Step 3: Apply Voucher (Optional) ==

    Customer -> Browser: Enter voucher "SUMMER2025"
    Browser -> Controller: POST /checkout/validate-voucher\n{voucherCode, totalAmount, eventId}
    activate Controller
    Controller -> VoucherSvc: validate("SUMMER2025",\n1600000, eventId)
    activate VoucherSvc
    VoucherSvc --> Controller: {valid: true,\ndiscount: 100000}
    deactivate VoucherSvc
    Controller --> Browser: JSON {discount: "100,000 VND",\nnewTotal: "1,500,000 VND"}
    deactivate Controller
    Browser -> Browser: Update UI:\nDiscount: -100,000 VND\nTotal: 1,500,000 VND

== Step 4: Submit Order ==

    Customer -> Browser: Fill buyer info + Confirm
    Browser -> Controller: POST /checkout/confirm\n{eventId, items[],\nbuyerName, buyerEmail,\nbuyerPhone, voucherCode, notes}
    activate Controller

    Controller -> Service: createOrder(orderData)
    activate Service

    Service -> DB: **BEGIN TRANSACTION**
    activate DB

    ' --- Create Order ---
    Service -> OrdDAO: create(order)
    activate OrdDAO
    OrdDAO -> DB: INSERT INTO Orders (\n  orderId, orderCode='ORD-'+random,\n  customerId, eventId,\n  buyerName, buyerEmail,\n  buyerPhone, notes,\n  subtotalAmount=1600000,\n  voucherId, eventDiscountAmount,\n  systemDiscountAmount,\n  totalAmount=1500000,\n  status='pending',\n  paymentMethod='bank_transfer',\n  paymentExpiry=NOW()+15min,\n  createdAt\n)
    OrdDAO --> Service: Order
    deactivate OrdDAO

    ' --- Create Order Items ---
    loop for each ticket type
        Service -> DB: INSERT INTO OrderItems (\n  orderItemId, orderId,\n  ticketTypeId, quantity,\n  unitPrice, totalPrice\n)
    end

    ' --- Update soldCount ---
    loop for each item
        Service -> TTDAO: incrementSoldCount(\nticketTypeId, qty)
        activate TTDAO
        TTDAO -> DB: UPDATE TicketTypes SET\nsoldCount = soldCount + ?\nWHERE ticketTypeId = ?\nAND (soldCount + ?) <= quantity
        TTDAO --> Service: OK
        deactivate TTDAO
    end

    ' --- Update Voucher usedCount ---
    opt has voucher
        Service -> DB: UPDATE Vouchers SET\nusedCount = usedCount + 1\nWHERE voucherId = ?
    end

    Service -> DB: **COMMIT**
    deactivate DB

    Service --> Controller: Order (created)
    deactivate Service

    Controller --> Browser: Redirect → /checkout/payment\n?orderId={orderId}
    deactivate Controller
    Browser --> Customer: → Continue to\nPayment page (SD-07)

end

@enduml
