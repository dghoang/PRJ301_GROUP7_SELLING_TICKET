@startuml SD_16_SecurityFilterChain
' ============================================================
' SEQUENCE DIAGRAM - Chuỗi Security Filter
' FR-Security: 7 Servlet Filters → Request Processing
' ============================================================

title **SD-16: Chuỗi Security Filter\n(7 Servlet Filters Chain)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #FFEBEE
    ParticipantBorderColor #B71C1C
    ArrowColor #B71C1C
}

actor "Any User" as User
participant "Browser" as Browser #LightYellow
participant "1. EncodingFilter" as F1 #FFCDD2
participant "2. SecurityHeadersFilter" as F2 #FFCDD2
participant "3. CsrfFilter" as F3 #FFCDD2
participant "4. XssFilter" as F4 #FFCDD2
participant "5. RateLimitFilter" as F5 #FFCDD2
participant "6. SessionRefreshFilter" as F6 #FFCDD2
participant "7. AccessControlFilter" as F7 #FFCDD2
participant "Target Servlet\n(Controller)" as Servlet #E8F5E9
database "SQL Server" as DB #F3E5F5

User -> Browser: HTTP Request
Browser -> F1: doFilter(request, response)
activate F1

== Filter 1: Encoding ==
F1 -> F1: request.setCharacterEncoding("UTF-8")\nresponse.setCharacterEncoding("UTF-8")\nresponse.setContentType(\n  "text/html;charset=UTF-8")

F1 -> F2: chain.doFilter(req, res)
activate F2

== Filter 2: Security Headers ==
F2 -> F2: response.setHeader(\n"X-Content-Type-Options", "nosniff")\nresponse.setHeader(\n"X-Frame-Options", "DENY")\nresponse.setHeader(\n"X-XSS-Protection", "1; mode=block")\nresponse.setHeader(\n"Referrer-Policy", "strict-origin")\nresponse.setHeader(\n"Content-Security-Policy", "...")

F2 -> F3: chain.doFilter(req, res)
activate F3

== Filter 3: CSRF Protection ==
F3 -> F3: if (method == POST/PUT/DELETE):\n  formToken = request.param("csrf_token")\n  cookieToken = cookie("csrf_token")\n  if (formToken != cookieToken)\n    → BLOCK

alt #FFE0E0 CSRF Token Invalid
    F3 --> Browser: HTTP 403 Forbidden\n"CSRF token mismatch"
    Browser --> User: ⛔ 403 Error
else #E8F5E9 CSRF Valid (or GET request)

    F3 -> F4: chain.doFilter(req, res)
    activate F4

    == Filter 4: XSS Protection ==
    F4 -> F4: Wrap request in XssRequestWrapper:\n- sanitize ALL parameters\n- HTML encode: <, >, &, ", '\n- Strip <script> tags\n- Clean dangerous attributes\n  (onerror, onload, onclick)

    F4 -> F5: chain.doFilter(wrappedReq, res)
    activate F5

    == Filter 5: Rate Limiting ==
    F5 -> F5: key = clientIP + sessionId\nbucket = rateLimitMap.get(key)\nif bucket.tokens <= 0\n  → HTTP 429 Too Many Requests
    F5 -> F5: Token Bucket Algorithm:\n- 100 requests/minute per IP\n- Refill 2 tokens/second

    alt #FFE0E0 Rate Limit Exceeded
        F5 --> Browser: HTTP 429\n"Quá nhiều request.\nVui lòng chờ."
        Browser --> User: ⚠️ Rate limited
    else #E8F5E9 Within Limit

        F5 -> F6: chain.doFilter(req, res)
        activate F6

        == Filter 6: Session Refresh (Remember Me) ==
        F6 -> F6: session = request.getSession(false)\nuser = session?.getAttribute("user")

        alt user == null (no active session)
            F6 -> F6: cookie = getCookie("st_refresh")
            alt st_refresh cookie exists
                F6 -> DB: SELECT rt.*, u.*\nFROM RefreshTokens rt\nJOIN Users u ON rt.userId=u.userId\nWHERE rt.token = ?\nAND rt.expiresAt > GETDATE()\nAND rt.isRevoked = 0
                activate DB
                DB --> F6: User + Token
                deactivate DB

                alt Token valid
                    F6 -> F6: **Auto-restore session:**\nsession = request.getSession(true)\nsession.setAttribute("user", user)\nsession.setAttribute("role", role)
                    F6 -> DB: UPDATE RefreshTokens\nSET lastUsedAt = GETDATE()
                else Token invalid/expired
                    F6 -> F6: Delete st_refresh cookie\n(expired token cleanup)
                end
            end
        end

        F6 -> F7: chain.doFilter(req, res)
        activate F7

        == Filter 7: Access Control (Role-based) ==
        F7 -> F7: url = request.getRequestURI()\nuser = session.getAttribute("user")

        F7 -> F7: **URL Pattern Matching:**\nif url.startsWith("/admin/")\n  → require role == "admin"\nif url.startsWith("/organizer/")\n  → require role == "organizer"\nif url.startsWith("/staff/")\n  → require role == "staff"\nif url.startsWith("/checkout/")\n  → require authenticated\nif url.startsWith("/profile/")\n  → require authenticated

        alt #FFE0E0 Not Authenticated
            F7 --> Browser: Redirect → /login\n?returnUrl={originalUrl}
            Browser --> User: Redirect to Login
        else #FFE0E0 Wrong Role
            F7 --> Browser: HTTP 403 Forbidden\n"Không có quyền truy cập"
            Browser --> User: ⛔ Access Denied
        else #E8F5E9 Authorized
            F7 -> Servlet: chain.doFilter(req, res)\n→ **Reach Target Servlet**
            activate Servlet
            Servlet -> Servlet: Process business logic...
            Servlet --> F7: Response
            deactivate Servlet
        end

        deactivate F7
        deactivate F6
    end
    deactivate F5
    deactivate F4
end
deactivate F3
deactivate F2
deactivate F1

Browser --> User: HTTP Response

@enduml
