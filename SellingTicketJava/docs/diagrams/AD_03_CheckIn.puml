@startuml AD_03_CheckIn
' ============================================================
' ACTIVITY DIAGRAM — Check-in Flow
' QR Scan → JWT Verify → Server Validate → Mark Checked-in
' ============================================================

title **Activity Diagram — Ticket Check-in Flow\n(Quét QR & Check-in)**

skinparam dpi 150
skinparam activity {
    BackgroundColor #E8EAF6
    BorderColor #283593
    ArrowColor #283593
    DiamondBackgroundColor #FFF3E0
}

|#E8EAF6|Staff / Organizer|
|#FFF3E0|System (Server)|
|#E0F7FA|Database|

|Staff / Organizer|
start
:Mở trang Check-in\n(GET /organizer/checkin?eventId=X);

|System (Server)|
:Verify quyền truy cập\n(isOrganizerOf || isStaffOf);

if (Có quyền?) then (Không)
    |Staff / Organizer|
    :403 Forbidden\n"Bạn không có quyền check-in\ncho sự kiện này";
    stop
else (Có)
endif

:Load danh sách vé\n+ CheckIn stats (total/checked/remaining);

|Staff / Organizer|
:Hiển thị giao diện Check-in\n📊 Stats: {checked}/{total}\n📷 Camera QR Scanner;

fork
    :===== Mode 1: QR Scan =====;
    :Camera quét QR Code trên vé;
    :Đọc JWT token từ QR;
partition (end)

fork again
    :===== Mode 2: Manual =====;
    :Nhập Ticket Code thủ công\n(TK-XXXXXXXXXXXX);
partition (end)
end fork

|System (Server)|

if (Mode?) then (QR Scan)
    :POST /api/organizer/checkin\n{qrToken: "eyJhbG...", eventId: X};
    
    :JwtUtil.verify(qrToken, SECRET_KEY);
    
    if (JWT hợp lệ?) then (Không)
        |Staff / Organizer|
        :❌ **QR Không hợp lệ**\n"Token bị giả mạo hoặc\nkhông đúng định dạng";
        stop
    else (Có)
        :Extract claims:\n{ticketId, eventId, ticketCode};
    endif
    
else (Manual)
    :POST /api/organizer/checkin\n{ticketCode: "TK-...", eventId: X};
endif

|Database|
:SELECT * FROM Tickets t\nJOIN OrderItems oi ON t.order_item_id = oi.order_item_id\nJOIN Orders o ON oi.order_id = o.order_id\nWHERE t.ticket_code = ? OR t.ticket_id = ?;

|System (Server)|

if (Tìm thấy vé?) then (Không)
    |Staff / Organizer|
    :❌ **Vé không tồn tại**\n"Không tìm thấy vé trong hệ thống";
    stop
else (Có)
endif

if (Vé thuộc event này?) then (Không)
    |Staff / Organizer|
    :❌ **Sai sự kiện**\n"Vé này thuộc sự kiện khác";
    stop
else (Có)
endif

if (Order đã paid?) then (Không - pending/cancelled)
    |Staff / Organizer|
    :❌ **Chưa thanh toán**\n"Đơn hàng chưa được xác nhận";
    stop
else (Có - paid)
endif

if (Đã check-in?) then (Đã check-in rồi)
    |Staff / Organizer|
    :⚠️ **Đã check-in trước đó**\n"Vé đã check-in lúc {checked_in_at}\nBởi {checked_in_by}";
    stop
else (Chưa)
endif

|Database|
:UPDATE Tickets SET\nis_checked_in = 1,\nchecked_in_at = GETDATE(),\nchecked_in_by = {staffId}\nWHERE ticket_id = ?;

|System (Server)|
:ActivityLog.log("ticket_checked_in",\nticketId, staffId);

:Cập nhật real-time stats:\nchecked_count += 1;

|Staff / Organizer|
:✅ **Check-in thành công!**\n\n🎫 Mã vé: TK-XXXX\n👤 Tên: {attendeeName}\n📧 Email: {attendeeEmail}\n🎟️ Loại: {ticketTypeName}\n⏰ Thời gian: {now}\n\n📊 {checked+1}/{total} đã check-in;

note right
  Giao diện tự động quay
  lại camera sau 3 giây
  để quét vé tiếp theo
end note

stop

@enduml
