@startuml SD_13_ProfileManagement
' ============================================================
' SEQUENCE DIAGRAM - Quản lý Hồ sơ Cá nhân
' FR-05, FR-06: Update Profile + Upload Avatar
' ============================================================

title **SD-13: Quản lý Hồ sơ Cá nhân\n(Profile Update + Avatar Upload)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1565C0
    ArrowColor #1565C0
}

actor "User\n(any role)" as User #LightBlue
participant "Browser" as Browser #LightYellow
participant "ProfileServlet\n(Controller)" as Controller #E3F2FD
participant "UserService" as Service #E8F5E9
participant "UserDAO" as DAO #FFF3E0
participant "CloudinaryService" as Cloud #E0F7FA
box "External" #F5F5F5
    participant "Cloudinary\nCDN" as CDN #FFCDD2
end box
database "SQL Server" as DB #F3E5F5

== Xem Profile ==

User -> Browser: Truy cập trang Profile
Browser -> Controller: GET /profile
activate Controller
Controller -> Controller: Get user from session\nuser = session.getAttribute("user")
Controller -> Service: getProfile(userId)
activate Service
Service -> DAO: findById(userId)
activate DAO
DAO -> DB: SELECT * FROM Users\nWHERE userId = ?
activate DB
DB --> DAO: User
deactivate DB
DAO --> Service: User
deactivate DAO
Service --> Controller: User
deactivate Service
Controller --> Browser: Forward → profile.jsp\n(user info, edit form)
deactivate Controller
Browser --> User: Profile page:\nAvatar, fullName, email,\nphone, gender, bio, address

== Cập nhật Profile ==

User -> Browser: Chỉnh sửa + Submit
Browser -> Controller: POST /profile\n{fullName, phone, gender,\nbio, address}
activate Controller

Controller -> Controller: Validate inputs

Controller -> Service: updateProfile(userId,\nupdateData)
activate Service
Service -> DAO: update(userId, fields)
activate DAO
DAO -> DB: UPDATE Users SET\nfullName=?, phone=?,\ngender=?, bio=?, address=?,\nupdatedAt=GETDATE()\nWHERE userId=?
activate DB
DB --> DAO: Updated
deactivate DB
DAO --> Service: OK
deactivate DAO

Service --> Controller: Updated User
deactivate Service

Controller -> Controller: Update session:\nsession.setAttribute("user", updatedUser)

Controller --> Browser: Redirect → /profile\n+ flash: "Cập nhật thành công"
deactivate Controller
Browser --> User: ✅ Profile đã cập nhật

== Upload Avatar ==

User -> Browser: Chọn ảnh avatar + Upload
Browser -> Controller: POST /profile/avatar\n{avatarFile (multipart)}
activate Controller

Controller -> Controller: Validate file:\n- Size ≤ 5MB\n- Type ∈ {jpg, png, gif, webp}

alt #FFE0E0 Invalid File
    Controller --> Browser: Redirect + error:\n"File không hợp lệ"
    Browser --> User: ❌ Lỗi upload
else #E8F5E9 Valid File

    Controller -> Cloud: uploadImage(\navatarFile, "avatars/")
    activate Cloud
    Cloud -> CDN: POST /v1_1/upload\n{file, folder: "avatars",\ntransformation: [\n  {width: 200, height: 200,\n   crop: "fill", gravity: "face"}\n]}
    activate CDN
    CDN --> Cloud: {\n  secure_url: "https://res.cloudinary.com/\n    .../avatars/abc123.jpg",\n  public_id: "avatars/abc123"\n}
    deactivate CDN
    Cloud --> Controller: imageUrl
    deactivate Cloud

    Controller -> Service: updateAvatar(\nuserId, imageUrl)
    activate Service
    Service -> DAO: updateAvatar(userId, url)
    activate DAO
    DAO -> DB: UPDATE Users SET\navatar = ?,\nupdatedAt = GETDATE()\nWHERE userId = ?
    activate DB
    DB --> DAO: Updated
    deactivate DB
    DAO --> Service: OK
    deactivate DAO
    Service --> Controller: Updated
    deactivate Service

    Controller -> Controller: Update session user avatar

    Controller --> Browser: Redirect → /profile\n+ flash: "Avatar đã cập nhật"
    Browser --> User: ✅ Avatar mới hiển thị
end

deactivate Controller

== Đổi Mật khẩu ==

User -> Browser: Click "Đổi mật khẩu"
Browser -> Controller: POST /profile/change-password\n{currentPassword, newPassword,\nconfirmNewPassword}
activate Controller

Controller -> Controller: Validate:\n- newPassword ≥ 8 chars\n- newPassword == confirm

Controller -> Service: changePassword(\nuserId, currentPw, newPw)
activate Service
Service -> DAO: findById(userId)
activate DAO
DAO -> DB: SELECT password FROM Users\nWHERE userId = ?
activate DB
DB --> DAO: hashedPassword
deactivate DB
DAO --> Service: user
deactivate DAO

Service -> Service: BCrypt.checkpw(\ncurrentPw, hashedPw)

alt #FFE0E0 Current Password Wrong
    Service --> Controller: "Mật khẩu hiện tại không đúng"
    Controller --> Browser: Forward + error message
    Browser --> User: ❌ Lỗi mật khẩu cũ
else #E8F5E9 Correct
    Service -> Service: newHash = BCrypt.hashpw(\nnewPw, genSalt(12))
    Service -> DAO: updatePassword(userId, newHash)
    activate DAO
    DAO -> DB: UPDATE Users SET\npassword = ?\nWHERE userId = ?
    activate DB
    DB --> DAO: Updated
    deactivate DB
    DAO --> Service: OK
    deactivate DAO
    Service --> Controller: Success
    deactivate Service
    Controller --> Browser: Redirect + flash:\n"Đã đổi mật khẩu thành công"
    Browser --> User: ✅ Password changed
end

deactivate Controller

@enduml
