@startuml SD_10_SupportTicket
' ============================================================
' SEQUENCE DIAGRAM - Support Ticket (Yêu cầu hỗ trợ)
' FR-31, FR-32: Tạo + Xử lý Support Ticket với Auto-routing
' ============================================================

title **SD-10: Support Ticket\n(Tạo & Xử lý Yêu cầu Hỗ trợ)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #E0F7FA
    ParticipantBorderColor #00838F
    ArrowColor #00838F
}

actor "Attendee" as Customer #LightBlue
participant "Browser" as Browser #LightYellow
participant "SupportServlet\n(Controller)" as Controller #E0F7FA
participant "SupportService" as Service #E8F5E9
participant "SupportTicketDAO" as DAO #FFF3E0
database "SQL Server" as DB #F3E5F5
participant "Admin/Org\nBrowser" as AdminBrowser #LightYellow
actor "Admin/\nOrganizer" as Handler #Orchid

== Bước 1: Tạo Support Ticket ==

Customer -> Browser: Click "Gửi yêu cầu hỗ trợ"
Browser -> Controller: GET /support/create
activate Controller
Controller -> DB: SELECT events WHERE\ncustomerId has orders
Controller --> Browser: Forward → create-ticket.jsp\n(categories, user events)
deactivate Controller
Browser --> Customer: Form tạo ticket

Customer -> Browser: Nhập:\n- category (payment_error)\n- subject\n- description\n- eventId (optional)\n- orderId (optional)
Browser -> Controller: POST /support/create\n{category, subject, description,\neventId, orderId}
activate Controller

Controller -> Service: createTicket(ticketData)
activate Service

' --- Auto-generate Ticket Code ---
Service -> Service: ticketCode = \n"SUP-" + RandomUtils\n.alphanumeric(6).toUpperCase()

' --- Auto-routing Logic ---
Service -> Service: **Auto-routing:**\nif eventId != null AND\ncategory ∈ {missing_ticket,\ncancellation, event_issue}\n→ assignedTo = "organizer"\n→ assignedUserId = event.organizerId\nelse\n→ assignedTo = "admin"\n→ assignedUserId = null (pool)

Service -> DAO: create(SupportTicket)
activate DAO
DAO -> DB: INSERT INTO SupportTickets\n(ticketId, ticketCode,\ncustomerId, category, subject,\ndescription, eventId, orderId,\nassignedTo, assignedUserId,\nstatus='open', priority='normal',\ncreatedAt)
activate DB
DB --> DAO: Created
deactivate DB
DAO --> Service: SupportTicket
deactivate DAO

' --- Notify Handler ---
Service -> DB: INSERT INTO Notifications\n(userId = assignedUserId,\ntype='NEW_SUPPORT_TICKET',\nmessage='Ticket mới: {subject}')

Service --> Controller: SupportTicket
deactivate Service
Controller --> Browser: Redirect → /support/tickets\n+ flash: "Đã gửi yêu cầu\nsố SUP-A1B2C3"
deactivate Controller
Browser --> Customer: ✅ Ticket đã tạo

== Bước 2: Handler Xử lý Ticket ==

Handler -> AdminBrowser: Xem Support Tickets
AdminBrowser -> Controller: GET /admin/support\n(hoặc /organizer/support)
activate Controller
Controller -> Service: getTickets(handlerUserId,\nstatus='open')
activate Service
Service -> DB: SELECT * FROM SupportTickets\nWHERE (assignedTo = 'admin'\nOR assignedUserId = ?)\nAND status IN ('open','in_progress')\nORDER BY priority DESC, createdAt
activate DB
DB --> Service: List<SupportTicket>
deactivate DB
Service --> Controller: tickets
deactivate Service
Controller --> AdminBrowser: Forward → support-list.jsp
deactivate Controller
AdminBrowser --> Handler: Danh sách tickets

Handler -> AdminBrowser: Mở ticket SUP-A1B2C3
AdminBrowser -> Controller: GET /admin/support/detail\n?ticketId={id}
activate Controller
Controller -> DB: SELECT ticket + responses\n+ customer info +\nevent info + order info
Controller --> AdminBrowser: Forward → ticket-detail.jsp
deactivate Controller
AdminBrowser --> Handler: Chi tiết ticket +\nlịch sử phản hồi

== Bước 3: Phản hồi + Cập nhật Status ==

Handler -> AdminBrowser: Nhập phản hồi + Đổi status
AdminBrowser -> Controller: POST /admin/support/respond\n{ticketId, response,\nnewStatus='in_progress'}
activate Controller

Controller -> Service: respondToTicket(\nticketId, handlerId,\nresponse, newStatus)
activate Service

Service -> DAO: createResponse(response)
activate DAO
DAO -> DB: INSERT INTO TicketResponses\n(responseId, ticketId,\nresponderId, responderRole,\nmessage, createdAt)
activate DB
DB --> DAO: Created
deactivate DB
DAO --> Service: OK
deactivate DAO

Service -> DAO: updateStatus(ticketId,\nnewStatus)
activate DAO
DAO -> DB: UPDATE SupportTickets\nSET status = 'in_progress',\nupdatedAt = GETDATE()\nWHERE ticketId = ?
activate DB
DB --> DAO: Updated
deactivate DB
DAO --> Service: OK
deactivate DAO

' --- Notify Customer ---
Service -> DB: INSERT INTO Notifications\n(userId=customerId,\ntype='TICKET_RESPONSE',\nmessage='Phản hồi ticket SUP-...')

Service --> Controller: OK
deactivate Service
Controller --> AdminBrowser: Redirect → ticket detail\n+ flash: "Đã phản hồi"
deactivate Controller
AdminBrowser --> Handler: ✅ Phản hồi đã gửi

== Bước 4: Resolve & Close ==

Handler -> AdminBrowser: Đổi status → "resolved"
AdminBrowser -> Controller: POST /admin/support/respond\n{ticketId, response:\n"Đã giải quyết xong",\nnewStatus='resolved'}
activate Controller
Controller -> Service: respondToTicket(...)
activate Service
Service -> DB: UPDATE status='resolved'\n+ INSERT response\n+ INSERT notification
Service --> Controller: OK
deactivate Service
Controller --> AdminBrowser: ✅ Ticket resolved
deactivate Controller

note over Controller
  Status flow:
  open → in_progress
  → resolved → closed
  Customer can reopen if
  still has issues.
end note

@enduml
