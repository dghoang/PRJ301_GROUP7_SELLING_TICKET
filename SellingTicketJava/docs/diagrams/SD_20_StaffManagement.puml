@startuml SD_20_StaffManagement
' ============================================================
' SEQUENCE DIAGRAM - Quản lý Staff (Organizer)
' FR-45: Organizer mời + quản lý nhân viên check-in
' ============================================================

title **SD-20: Quản lý Nhân viên\n(Staff Assignment + Check-in Permissions)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #FFF3E0
    ParticipantBorderColor #E65100
    ArrowColor #E65100
}

actor "Organizer" as Organizer #Gold
participant "Browser" as Browser #LightYellow
participant "StaffServlet\n(Controller)" as Controller #FFF3E0
participant "StaffService" as Service #E8F5E9
participant "UserDAO" as UserDAO #FFF3E0
participant "StaffAssignmentDAO" as StaffDAO #FFF3E0
database "SQL Server" as DB #F3E5F5
actor "Staff" as Staff #LightCoral

== Bước 1: Xem danh sách Staff ==

Organizer -> Browser: Truy cập Staff Management
Browser -> Controller: GET /organizer/staff
activate Controller
Controller -> Service: getStaffList(organizerId)
activate Service
Service -> StaffDAO: findByOrganizer(organizerId)
activate StaffDAO
StaffDAO -> DB: SELECT sa.*, u.fullName, u.email,\nu.avatar, e.title as eventTitle\nFROM StaffAssignments sa\nJOIN Users u ON sa.staffId = u.userId\nJOIN Events e ON sa.eventId = e.eventId\nWHERE e.organizerId = ?\nORDER BY sa.assignedAt DESC
activate DB
DB --> StaffDAO: List<StaffAssignment>
deactivate DB
StaffDAO --> Service: staff list
deactivate StaffDAO
Service --> Controller: staff list
deactivate Service
Controller --> Browser: Forward → staff-list.jsp
deactivate Controller
Browser --> Organizer: Danh sách staff:\nName, Email, Event, Role, Status

== Bước 2: Thêm Staff cho Event ==

Organizer -> Browser: Click "Thêm Staff"\nNhập email staff + chọn event
Browser -> Controller: POST /organizer/staff/add\n{staffEmail, eventId, staffRole}
activate Controller

Controller -> Service: assignStaff(\nstaffEmail, eventId, organizerId)
activate Service

' --- Find Staff User ---
Service -> UserDAO: findByEmail(staffEmail)
activate UserDAO
UserDAO -> DB: SELECT * FROM Users\nWHERE email = ?
activate DB
DB --> UserDAO: User or null
deactivate DB
UserDAO --> Service: user
deactivate UserDAO

alt #FFE0E0 User Not Found
    Service --> Controller: "Không tìm thấy user\nvới email này"
    Controller --> Browser: Error message
    Browser --> Organizer: ❌ User not found
else #E8F5E9 User Found

    ' --- Verify Event Ownership ---
    Service -> DB: SELECT * FROM Events\nWHERE eventId = ?\nAND organizerId = ?
    activate DB
    DB --> Service: Event
    deactivate DB

    ' --- Check Not Duplicate ---
    Service -> StaffDAO: findByStaffAndEvent(\nstaffId, eventId)
    activate StaffDAO
    StaffDAO -> DB: SELECT * FROM StaffAssignments\nWHERE staffId = ? AND eventId = ?
    activate DB
    DB --> StaffDAO: null (not assigned yet)
    deactivate DB
    StaffDAO --> Service: null
    deactivate StaffDAO

    ' --- Create Assignment ---
    Service -> StaffDAO: create(assignment)
    activate StaffDAO
    StaffDAO -> DB: INSERT INTO StaffAssignments\n(assignmentId, staffId, eventId,\nstaffRole='check_in',\nassignedBy=organizerId,\nassignedAt=GETDATE(), isActive=true)
    activate DB
    DB --> StaffDAO: Created
    deactivate DB
    StaffDAO --> Service: OK
    deactivate StaffDAO

    ' --- Update User Role (if needed) ---
    Service -> UserDAO: updateRole(staffId, "staff")
    activate UserDAO
    UserDAO -> DB: UPDATE Users SET role = 'staff'\nWHERE userId = ?\nAND role = 'customer'
    activate DB
    DB --> UserDAO: Updated
    deactivate DB
    UserDAO --> Service: OK
    deactivate UserDAO

    ' --- Notify Staff ---
    Service -> DB: INSERT Notifications\n(userId=staffId,\ntype='STAFF_ASSIGNED',\nmessage='Bạn đã được thêm làm\nnhân viên check-in cho event X')

    Service --> Controller: Success
    deactivate Service
    Controller --> Browser: Redirect + flash:\n"Đã thêm staff thành công"
    deactivate Controller
    Browser --> Organizer: ✅ Staff added

end

== Bước 3: Staff truy cập Check-in ==

Staff -> Browser: Đăng nhập (role=staff)
Browser -> Controller: GET /staff/dashboard
activate Controller
Controller -> Service: getAssignedEvents(staffId)
activate Service
Service -> StaffDAO: findByStaff(staffId)
activate StaffDAO
StaffDAO -> DB: SELECT e.*, sa.staffRole\nFROM StaffAssignments sa\nJOIN Events e ON sa.eventId=e.eventId\nWHERE sa.staffId=?\nAND sa.isActive=true
activate DB
DB --> StaffDAO: List<Event>
deactivate DB
StaffDAO --> Service: assigned events
deactivate StaffDAO
Service --> Controller: events
deactivate Service
Controller --> Browser: Forward → staff/dashboard.jsp
deactivate Controller
Browser --> Staff: Dashboard: Danh sách events\nđược phân quyền check-in

note over Staff, Browser
  Staff click vào event
  → Chuyển tới trang Check-in
  → Luồng SD-08 (QR Check-in)
end note

@enduml
