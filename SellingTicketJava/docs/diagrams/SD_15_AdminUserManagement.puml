@startuml SD_15_AdminUserManagement
' ============================================================
' SEQUENCE DIAGRAM - Admin User Management
' FR-42~FR-44: CRUD Users + Ban/Unban + Search/Filter
' ============================================================

title **SD-15: Admin User Management\n(View / Search / Ban / Delete Users)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #EFEBE9
    ParticipantBorderColor #4E342E
    ArrowColor #4E342E
}

actor "Admin" as Admin #Orchid
participant "Browser" as Browser #LightYellow
participant "AdminUserServlet\n(Controller)" as Controller #EFEBE9
participant "UserService" as Service #E8F5E9
participant "UserDAO" as DAO #FFF3E0
participant "NotificationService" as NotifSvc #E0F7FA
database "SQL Server" as DB #F3E5F5

== Step 1: View User List ==

Admin -> Browser: Open User Management
Browser -> Controller: GET /admin/users\n?page=1&role=&search=
activate Controller
Controller -> Service: getUsers(page, role, search)
activate Service
Service -> DAO: findAll(page, role, search)
activate DAO
DAO -> DB: SELECT u.*, \nCOUNT(DISTINCT o.orderId) as orderCount\nFROM Users u\nLEFT JOIN Orders o ON u.userId=o.customerId\nWHERE u.isDeleted = 0\nAND (u.role = ? OR ? IS NULL)\nAND (u.fullName LIKE '%?%'\n  OR u.email LIKE '%?%')\nGROUP BY u.userId\nORDER BY u.createdAt DESC\nOFFSET ? ROWS FETCH NEXT 20 ROWS ONLY
activate DB
DB --> DAO: List<User> + totalCount
deactivate DB
DAO --> Service: users, total
deactivate DAO
Service --> Controller: users, pagination
deactivate Service
Controller --> Browser: Forward → admin/users.jsp
deactivate Controller
Browser --> Admin: User list table:\nName, Email, Role, Status,\nRegistered Date, Actions

== Step 2: Ban/Unban User ==

Admin -> Browser: Click "Ban" on user
Browser -> Controller: POST /admin/users/toggle-status\n{userId, action: "ban"}
activate Controller

Controller -> Service: toggleUserStatus(\nuserId, "ban", adminId)
activate Service

Service -> DAO: updateStatus(userId, isActive=false)
activate DAO
DAO -> DB: UPDATE Users SET\nisActive = 0\nWHERE userId = ?
activate DB
DB --> DAO: Updated
deactivate DB
DAO --> Service: OK
deactivate DAO

' --- Activity Log ---
Service -> DB: INSERT INTO ActivityLogs\n(userId=adminId,\naction='BAN_USER',\ndetails='Banned userId={id}')

' --- Notify User ---
Service -> NotifSvc: notify(userId,\n"Your account has been\nsuspended. Contact\nsupport for details.",\n'ACCOUNT_BANNED')

Service --> Controller: Success
deactivate Service
Controller --> Browser: Redirect + flash:\n"User has been banned"
deactivate Controller
Browser --> Admin: ✅ User banned

== Step 3: Soft-delete User ==

Admin -> Browser: Click "Delete" on user
Browser -> Browser: Confirm dialog:\n"Are you sure you want to\ndelete this user?"
Admin -> Browser: Confirm
Browser -> Controller: POST /admin/users/delete\n{userId}
activate Controller

Controller -> Service: softDelete(userId, adminId)
activate Service
Service -> DAO: softDelete(userId)
activate DAO
DAO -> DB: UPDATE Users SET\nisDeleted = 1,\ndeletedAt = GETDATE()\nWHERE userId = ?
activate DB
DB --> DAO: Updated
deactivate DB
DAO --> Service: OK
deactivate DAO

Service -> DB: INSERT ActivityLogs\n(action='DELETE_USER')

Service --> Controller: Success
deactivate Service
Controller --> Browser: Redirect + flash:\n"User deleted"
deactivate Controller
Browser --> Admin: ✅ User deleted\n(soft-delete)

@enduml
