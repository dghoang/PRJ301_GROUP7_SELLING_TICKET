@startuml SD_06_TicketPurchase
' ============================================================
' SEQUENCE DIAGRAM - Mua Vé Toàn Trình (Full Ticket Purchase)
' FR-18~FR-22: Select → Checkout → Payment → Ticket Generation
' ============================================================

title **SD-06: Mua Vé Sự Kiện - Toàn Trình\n(Full Ticket Purchase Flow)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 180
skinparam sequence {
    ParticipantBackgroundColor #FCE4EC
    ParticipantBorderColor #C62828
    ArrowColor #C62828
}

actor "Attendee" as User #LightBlue
participant "Browser\n(JSP)" as Browser #LightYellow
participant "EventDetailServlet" as EvtCtrl #FCE4EC
participant "CheckoutServlet" as ChkCtrl #FCE4EC
participant "OrderService" as OrderSvc #E8F5E9
participant "VoucherService" as VouchSvc #E0F7FA
participant "TicketTypeDAO" as TTDAO #FFF3E0
participant "OrderDAO" as OrderDAO #FFF3E0
participant "TicketDAO" as TicketDAO #FFF3E0
database "SQL Server" as DB #F3E5F5

== Phase 1: Xem Chi tiết & Chọn Vé ==

User -> Browser: Truy cập trang chi tiết sự kiện
Browser -> EvtCtrl: GET /events/{slug}
activate EvtCtrl

EvtCtrl -> DB: SELECT event + ticketTypes\nWHERE slug = ? AND status = 'approved'
activate DB
DB --> EvtCtrl: Event + List<TicketType>\n(name, price, quantity, soldCount,\nsaleStart, saleEnd)
deactivate DB

EvtCtrl -> DB: UPDATE Events SET\nviews = views + 1\nWHERE eventId = ?
EvtCtrl --> Browser: Forward → event-detail.jsp
deactivate EvtCtrl
Browser --> User: Chi tiết sự kiện +\nCác loại vé (giá, còn lại)

User -> Browser: Chọn loại vé + số lượng\n(VIP x2, Standard x3)\nClick "Mua vé"

== Phase 2: Trang Checkout ==

Browser -> ChkCtrl: POST /checkout\n{ticketTypeId[], quantities[],\neventId}
activate ChkCtrl

' --- Validate Availability ---
loop for each selected TicketType
    ChkCtrl -> TTDAO: findById(ticketTypeId)
    activate TTDAO
    TTDAO -> DB: SELECT * FROM TicketTypes\nWHERE ticketTypeId = ?
    activate DB
    DB --> TTDAO: TicketType
    deactivate DB
    TTDAO --> ChkCtrl: ticketType
    deactivate TTDAO

    ChkCtrl -> ChkCtrl: Validate:\n- isActive == true\n- saleStart ≤ now ≤ saleEnd\n- quantity - soldCount ≥ requestedQty\n- requestedQty ≤ maxTicketsPerOrder
end

alt #FFE0E0 Validation Failed
    ChkCtrl --> Browser: Forward → event page\n+ "Vé đã hết" / "Vượt giới hạn"
    Browser --> User: ❌ Thông báo lỗi
else #E8F5E9 All Valid

    ChkCtrl -> ChkCtrl: Tính tổng:\nsubTotal = Σ(price × qty)
    ChkCtrl --> Browser: Forward → checkout.jsp\n(items, subTotal, form)
    deactivate ChkCtrl
    Browser --> User: Trang Checkout:\n- Danh sách vé đã chọn\n- Tổng tiền\n- Form: buyerName, email, phone\n- Ô nhập Voucher code
end

== Phase 3: Áp dụng Voucher (Optional) ==

opt Attendee nhập mã Voucher
    User -> Browser: Nhập voucher code\n+ Click "Áp dụng"
    Browser -> ChkCtrl: POST /checkout/validate-voucher\n{voucherCode, totalAmount, eventId}
    activate ChkCtrl

    ChkCtrl -> VouchSvc: validateVoucher(\ncode, totalAmount, eventId)
    activate VouchSvc
    VouchSvc -> DB: SELECT * FROM Vouchers\nWHERE code = ? AND isActive = 1
    activate DB
    DB --> VouchSvc: Voucher or null
    deactivate DB

    VouchSvc -> VouchSvc: Validate chain:\n1. exists?\n2. isActive?\n3. startDate ≤ now ≤ endDate?\n4. usedCount < usageLimit?\n5. totalAmount ≥ minOrderAmount?\n6. scope matches? (event/system)

    alt #FFE0E0 Invalid Voucher
        VouchSvc --> ChkCtrl: VoucherException\n(reason message)
        ChkCtrl --> Browser: JSON: {success:false,\nmessage: "Mã không hợp lệ"}
        Browser --> User: ❌ "Voucher không hợp lệ"
    else #E8F5E9 Valid Voucher
        VouchSvc -> VouchSvc: Calculate discount:\nif percentage:\n  disc = min(total × %, maxDisc)\nif fixed:\n  disc = min(value, total)
        VouchSvc --> ChkCtrl: VoucherResult\n{discountAmount, voucherId}
        deactivate VouchSvc
        ChkCtrl --> Browser: JSON: {success:true,\ndiscount: 50000, newTotal: 450000}
        deactivate ChkCtrl
        Browser --> User: ✅ Giảm 50,000₫\nTổng mới: 450,000₫
    end
end

== Phase 4: Submit Đơn hàng (Atomic Transaction) ==

User -> Browser: Nhập buyer info + Submit
Browser -> ChkCtrl: POST /checkout/place-order\n{buyerName, buyerEmail, buyerPhone,\nnotes, voucherCode,\nticketTypeId[], quantities[]}
activate ChkCtrl

ChkCtrl -> OrderSvc: placeOrder(orderData)
activate OrderSvc

OrderSvc -> DB: **BEGIN TRANSACTION**
activate DB

note over OrderSvc, DB
  ⚠️ **ATOMIC OPERATION**
  All-or-nothing: nếu bất kỳ step
  nào fail → ROLLBACK toàn bộ
end note

' --- Step 1: Create Order ---
OrderSvc -> OrderDAO: create(order)
activate OrderDAO
OrderDAO -> DB: INSERT INTO Orders\n(orderId, orderCode, eventId,\ncustomerId, buyerName, buyerEmail,\nbuyerPhone, notes,\nsubTotal, eventDiscountAmount,\nsystemDiscountAmount, totalAmount,\nvoucherId, status='pending',\ncreatedAt=GETDATE())
DB --> OrderDAO: orderId
deactivate OrderDAO

' --- Step 2: Create Order Items ---
loop for each ticket type selected
    OrderSvc -> OrderDAO: createOrderItem(item)
    OrderDAO -> DB: INSERT INTO OrderItems\n(orderItemId, orderId,\nticketTypeId, quantity,\nunitPrice, subtotal)
end

' --- Step 3: Update soldCount ---
loop for each ticket type
    OrderSvc -> TTDAO: incrementSoldCount(\nticketTypeId, quantity)
    activate TTDAO
    TTDAO -> DB: UPDATE TicketTypes\nSET soldCount = soldCount + ?\nWHERE ticketTypeId = ?\nAND (quantity - soldCount) >= ?
    DB --> TTDAO: rowsAffected
    deactivate TTDAO

    alt rowsAffected == 0
        OrderSvc -> DB: **ROLLBACK**
        OrderSvc --> ChkCtrl: ConcurrencyException\n("Vé đã hết trong quá trình xử lý")
    end
end

' --- Step 4: Update Voucher usage ---
opt voucherId != null
    OrderSvc -> DB: UPDATE Vouchers\nSET usedCount = usedCount + 1\nWHERE voucherId = ?
end

OrderSvc -> DB: **COMMIT TRANSACTION**
deactivate DB

OrderSvc --> ChkCtrl: Order (created, status=pending)
deactivate OrderSvc

ChkCtrl --> Browser: Redirect → /checkout/payment\n?orderId={orderId}
deactivate ChkCtrl
Browser --> User: Chuyển tới trang thanh toán

@enduml
