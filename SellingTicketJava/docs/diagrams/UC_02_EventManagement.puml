@startuml UC_02_EventManagement
' ============================================================
' USE CASE DIAGRAM - MODULE 2: Event Management
' Event Lifecycle Management
' ============================================================

title **Use Case Diagram - Module 2\nEvent Management**

left to right direction
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #FFF3E0
    BorderColor #E65100
    FontSize 12
    ArrowColor #E65100
}

' === ACTORS ===
actor "Guest\n(Unregistered)" as Guest #LightGreen
actor "Attendee\n(Customer)" as Attendee #LightBlue
actor "Organizer" as Organizer #Gold
actor "Admin" as Admin #Orchid

' === EXTERNAL ===
actor "Cloudinary\nCDN" as Cloud #LightGray

' === SYSTEM BOUNDARY ===
rectangle "Module 2: Event Management" {

    usecase "**UC-2.1: Browse Events**\n---\nView list of approved events.\nPagination, filter\nby category, sort by date." as UC_BROWSE

    usecase "**UC-2.2: Search Events**\n---\nSearch by title,\nlocation, description.\nLIKE query + filters." as UC_SEARCH

    usecase "**UC-2.3: View Event Detail**\n---\nFull info: banner,\ntitle, date, location,\ndescription, organizer,\nticket types." as UC_DETAIL

    usecase "**UC-2.4: Create Event**\n---\nMulti-step form:\nbasic info, banner upload,\nticket types.\nAuto-generate slug.\nStatus: pending." as UC_CREATE

    usecase "**UC-2.5: Edit Event**\n---\nOrganizer edits\nownEvent info.\nOnly pending/approved\nevents." as UC_EDIT

    usecase "**UC-2.6: Delete Event**\n---\nSoft-delete (isDeleted=true).\nOnly events with no\nconfirmed orders." as UC_DELETE

    usecase "**UC-2.7: Manage Ticket Types**\n---\nAdd/Edit/Delete ticket types\nfor an event.\nFields: name, price,\nquantity, saleStart/End." as UC_TICKET

    usecase "**UC-2.8: Approve Event**\n---\nAdmin reviews and\napproves pending events.\nStatus: pending → approved." as UC_APPROVE

    usecase "**UC-2.9: Reject Event**\n---\nAdmin rejects with reason.\nStatus: pending → rejected.\nNotify organizer." as UC_REJECT

    ' --- Sub use cases ---
    usecase "Upload Banner\n(Cloudinary)" as UC_UPLOAD <<include>>

    usecase "Auto-generate\nSlug" as UC_SLUG <<include>>

    usecase "Increment\nView Count" as UC_VIEW <<include>>

    usecase "Mark as\nFeatured" as UC_FEATURE <<extend>>
}

' === ASSOCIATIONS ===
Guest --> UC_BROWSE
Guest --> UC_SEARCH
Guest --> UC_DETAIL

Attendee --> UC_BROWSE
Attendee --> UC_SEARCH
Attendee --> UC_DETAIL

Organizer --> UC_CREATE
Organizer --> UC_EDIT
Organizer --> UC_DELETE
Organizer --> UC_TICKET

Admin --> UC_APPROVE
Admin --> UC_REJECT
Admin --> UC_BROWSE

Cloud --> UC_UPLOAD

' === INCLUDE / EXTEND ===
UC_CREATE ..> UC_UPLOAD : <<include>>
UC_CREATE ..> UC_SLUG : <<include>>
UC_DETAIL ..> UC_VIEW : <<include>>
UC_APPROVE <.. UC_FEATURE : <<extend>>

' === NOTES ===
note right of UC_CREATE
  **FR-07, FR-08**
  Status lifecycle:
  pending → approved → completed
  pending → rejected
  Organizer can resubmit
  after rejection.
end note

note right of UC_TICKET
  **FR-09**
  Each event can have
  multiple ticket types.
  soldCount auto-updated
  at checkout.
end note

note bottom of UC_APPROVE
  **FR-10**
  Only Admin can approve.
  Notification sent to
  organizer upon
  approve/reject.
end note

@enduml
