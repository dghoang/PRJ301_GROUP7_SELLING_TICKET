@startuml SD_04_CreateEvent
' ============================================================
' SEQUENCE DIAGRAM - Create Event
' FR-07, FR-08: Create Event + Upload Banner + Ticket Types
' ============================================================

title **SD-04: Create Event\n(Multi-step Form → Approval)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #FFF3E0
    ParticipantBorderColor #E65100
    ArrowColor #E65100
}

actor "Organizer" as Organizer #Gold
participant "Browser" as Browser #LightYellow
participant "EventServlet\n(Controller)" as Controller #FFF3E0
participant "EventService" as Service #E8F5E9
participant "EventDAO" as DAO #FFF3E0
participant "TicketTypeDAO" as TTDAO #FFF3E0
participant "CloudinaryService" as Cloud #E0F7FA
box "External" #F5F5F5
    participant "Cloudinary\nCDN" as CDN #FFCDD2
end box
database "SQL Server" as DB #F3E5F5

== Step 1: Open Create Form ==

Organizer -> Browser: Click "Create Event"
Browser -> Controller: GET /organizer/events/create
activate Controller
Controller -> DB: SELECT * FROM Categories\nWHERE isActive = 1
activate DB
DB --> Controller: categories list
deactivate DB
Controller --> Browser: Forward → create-event.jsp\n(categories dropdown,\nmulti-step form)
deactivate Controller
Browser --> Organizer: Multi-step form:\n1. Basic Info\n2. Banner Upload\n3. Ticket Types\n4. Review & Submit

== Step 2: Fill Basic Info + Upload Banner ==

Organizer -> Browser: Fill in: title, description,\nlocation, address,\nstartDate, endDate,\ncategory, isPrivate\n+ Select banner image

== Step 3: Add Ticket Types ==

Organizer -> Browser: Add ticket types:\n[VIP] 500,000 VND × 100\n[Standard] 200,000 VND × 300\n[Early Bird] 150,000 VND × 50

== Step 4: Submit Form ==

Browser -> Controller: POST /organizer/events/create\n(multipart/form-data)\n{title, description, location,\naddress, startDate, endDate,\ncategoryId, isPrivate,\nbannerImage (file),\nticketTypes[] (JSON)}
activate Controller

Controller -> Controller: Server-side validation:\n- title not blank\n- startDate < endDate\n- ≥ 1 ticket type\n- price ≥ 0, quantity > 0

alt #FFE0E0 Validation Failed
    Controller --> Browser: Forward → create-event.jsp\n+ error messages
    Browser --> Organizer: ❌ Fix errors
else #E8F5E9 Validation OK

    ' --- Upload Banner ---
    Controller -> Cloud: uploadImage(bannerFile,\n"events/")
    activate Cloud
    Cloud -> CDN: POST /v1_1/upload\n{file, folder: "events",\ntransformation: [...]}
    activate CDN
    CDN --> Cloud: {secure_url:\n"https://res...events/xxx.jpg"}
    deactivate CDN
    Cloud --> Controller: bannerUrl
    deactivate Cloud

    ' --- Create Event ---
    Controller -> Service: createEvent(eventData)
    activate Service

    Service -> Service: Auto-generate slug:\n"summer-music-2025"\n(from title, Vietnamese\ndiacritics removed)

    Service -> DAO: create(event)
    activate DAO
    DAO -> DB: BEGIN TRANSACTION\n\nINSERT INTO Events (\n  eventId, title, slug,\n  shortDescription, description,\n  location, address,\n  bannerImage, startDate,\n  endDate, categoryId,\n  organizerId, status='pending',\n  isPrivate, isFeatured=0,\n  viewCount=0, createdAt\n)
    activate DB
    DB --> DAO: eventId (new)
    deactivate DB
    DAO --> Service: Event
    deactivate DAO

    ' --- Create Ticket Types ---
    loop for each ticketType
        Service -> TTDAO: create(ticketType)
        activate TTDAO
        TTDAO -> DB: INSERT INTO TicketTypes (\n  ticketTypeId, eventId,\n  name, description, price,\n  quantity, soldCount=0,\n  saleStart, saleEnd,\n  sortOrder, isActive=1\n)
        activate DB
        DB --> TTDAO: Created
        deactivate DB
        TTDAO --> Service: OK
        deactivate TTDAO
    end

    Service -> DB: COMMIT

    ' --- Notify Admin ---
    Service -> DB: INSERT INTO Notifications\n(userId=adminId,\ntype='EVENT_PENDING',\nmessage='New event pending\napproval: {title}')

    Service --> Controller: Event (created)
    deactivate Service

    Controller --> Browser: Redirect →\n/organizer/events\n+ flash: "Event created\nsuccessfully!\nAwaiting admin approval."
    deactivate Controller
    Browser --> Organizer: ✅ Event created,\nstatus: Pending

end

@enduml
