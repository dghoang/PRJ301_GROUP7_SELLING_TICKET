@startuml UC_04_Checkin
' ============================================================
' USE CASE DIAGRAM - MODULE 4: QR Check-in
' QR Code Scanning + Validation + Statistics
' ============================================================

title **Use Case Diagram - Module 4\nQR Code Check-in**

left to right direction
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #F3E5F5
    BorderColor #7B1FA2
    FontSize 12
    ArrowColor #7B1FA2
}

' === ACTORS ===
actor "Staff\n(Event Staff)" as Staff #LightCoral
actor "Organizer" as Organizer #Gold

' === SYSTEM BOUNDARY ===
rectangle "Module 4: QR Check-in" {

    usecase "**UC-4.1: QR Code Check-in**\n---\nStaff scans attendee's\nticket QR code.\nValidate 4 conditions.\nMark isCheckedIn=true." as UC_CHECKIN

    usecase "**UC-4.2: Manual Code Entry**\n---\nManually enter ticket code\n(camera failure case).\nSame validation as QR." as UC_MANUAL

    usecase "**UC-4.3: View Check-in Statistics**\n---\nReal-time stats:\ntotal, checked-in,\nremaining, percentage." as UC_STATS

    usecase "**UC-4.4: View Check-in List**\n---\nList of checked-in attendees.\nSearch by name/code.\nTable: name, type, time." as UC_LIST

    ' --- Sub use cases ---
    usecase "Validate\nTicket\n(4 conditions)" as UC_VALID <<include>>

    usecase "jsQR\nCamera Scan" as UC_SCAN <<include>>
}

' === ASSOCIATIONS ===
Staff --> UC_CHECKIN
Staff --> UC_MANUAL
Staff --> UC_STATS
Staff --> UC_LIST

Organizer --> UC_STATS
Organizer --> UC_LIST

' === INCLUDE ===
UC_CHECKIN ..> UC_VALID : <<include>>
UC_CHECKIN ..> UC_SCAN : <<include>>
UC_MANUAL ..> UC_VALID : <<include>>

' === NOTES ===
note right of UC_VALID
  **4-Condition Validation:**
  1. ✅ Ticket code exists?
  2. ✅ Correct event?
  3. ✅ Order confirmed?
  4. ✅ Not already checked in?
end note

note right of UC_CHECKIN
  **FR-26~FR-28**
  Check-in result UI:
  ✅ Green = Success
  ⚠️ Yellow = Duplicate
  ❌ Red = Invalid
  + Sound effects
end note

@enduml
