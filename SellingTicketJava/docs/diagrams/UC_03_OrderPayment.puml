@startuml UC_03_OrderPayment
' ============================================================
' USE CASE DIAGRAM - MODULE 3: Order & Payment
' Order & Payment Processing
' ============================================================

title **Use Case Diagram - Module 3\nOrder & Payment**

left to right direction
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #FCE4EC
    BorderColor #C62828
    FontSize 12
    ArrowColor #C62828
}

' === ACTORS ===
actor "Attendee\n(Customer)" as Attendee #LightBlue
actor "Organizer" as Organizer #Gold
actor "Admin" as Admin #Orchid

' === EXTERNAL ===
actor "SePay\n(VietQR)" as SePay #LightGray

' === SYSTEM BOUNDARY ===
rectangle "Module 3: Order & Payment" {

    usecase "**UC-3.1: Select Tickets**\n---\nCustomer selects\nticket types +\nquantities.\nCheck availability\n(remaining qty)." as UC_SELECT

    usecase "**UC-3.2: Checkout**\n---\nFill buyer info:\nname, email, phone.\nVoucher input.\nCalculate totalAmount." as UC_CHECKOUT

    usecase "**UC-3.3: VietQR Payment**\n---\nGenerate QR via SePay.\nCustomer scans and transfers.\n15-minute payment expiry.\nWebhook auto-confirm." as UC_PAY

    usecase "**UC-3.4: View My Tickets**\n---\nCustomer views list of\npurchased tickets.\nQR code + ticket info.\nFilter by event." as UC_MYTICKET

    usecase "**UC-3.5: Cancel Order**\n---\nCancel pending order.\nRestore ticket inventory\n(revert soldCount)." as UC_CANCEL

    usecase "**UC-3.6: Manual Payment\nConfirmation**\n---\nAdmin/Organizer manually\nconfirm payment for orders\nnot auto-confirmed via webhook." as UC_MANUAL

    usecase "**UC-3.7: View All Orders**\n---\nOrganizer/Admin views\nall orders.\nFilter: status, event,\ndate range.\nExport data." as UC_ORDERS

    ' --- Sub use cases ---
    usecase "Check Ticket\nAvailability\n(soldCount < quantity)" as UC_AVAIL <<include>>

    usecase "Generate QR\n(VietQR URL)" as UC_QR <<include>>

    usecase "Webhook\nPayment Matching\n(5-layer validation)" as UC_WEBHOOK <<include>>

    usecase "Issue E-Tickets\n(ticketCode + QR)" as UC_ISSUE <<include>>

    usecase "Payment Expiry\nAuto-cancel (15min)" as UC_EXPIRE <<extend>>

    usecase "Apply\nVoucher" as UC_VOUCHER <<extend>>
}

' === ASSOCIATIONS ===
Attendee --> UC_SELECT
Attendee --> UC_CHECKOUT
Attendee --> UC_MYTICKET
Attendee --> UC_CANCEL

Organizer --> UC_MANUAL
Organizer --> UC_ORDERS

Admin --> UC_MANUAL
Admin --> UC_ORDERS

SePay --> UC_WEBHOOK

' === INCLUDE / EXTEND ===
UC_SELECT ..> UC_AVAIL : <<include>>
UC_PAY ..> UC_QR : <<include>>
UC_PAY ..> UC_WEBHOOK : <<include>>
UC_PAY ..> UC_ISSUE : <<include>>
UC_CHECKOUT ..> UC_PAY : <<include>>

UC_CHECKOUT <.. UC_VOUCHER : <<extend>>
UC_PAY <.. UC_EXPIRE : <<extend>>

' === NOTES ===
note right of UC_CHECKOUT
  **FR-18~FR-21**
  Order stores:
  subtotalAmount
  eventDiscountAmount
  systemDiscountAmount
  totalAmount
  paymentExpiry
end note

note right of UC_PAY
  **FR-20**
  SePay Webhook:
  5-layer validation:
  1. API Key match
  2. transferType = "in"
  3. Content-Length ≤ 1MB
  4. Parse orderCode
  5. Amount match
end note

note bottom of UC_ISSUE
  **FR-22**
  Each OrderItem generates
  {quantity} tickets.
  ticketCode = "TKT-" + random.
  qrCodeData = JWT signed.
end note

@enduml
