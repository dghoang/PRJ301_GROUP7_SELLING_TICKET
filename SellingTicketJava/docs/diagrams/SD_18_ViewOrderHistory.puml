@startuml SD_18_ViewOrderHistory
' ============================================================
' SEQUENCE DIAGRAM - Xem Đơn hàng & Vé của tôi
' FR-23, FR-24: Order History + My Tickets
' ============================================================

title **SD-18: Xem Đơn hàng & Vé\n(Order History + My Tickets)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #FCE4EC
    ParticipantBorderColor #C62828
    ArrowColor #C62828
}

actor "Attendee" as User #LightBlue
participant "Browser" as Browser #LightYellow
participant "OrderServlet\n(Controller)" as OrderCtrl #FCE4EC
participant "TicketServlet\n(Controller)" as TktCtrl #FCE4EC
participant "OrderService" as OrderSvc #E8F5E9
participant "TicketService" as TktSvc #E8F5E9
participant "OrderDAO" as OrdDAO #FFF3E0
participant "TicketDAO" as TktDAO #FFF3E0
database "SQL Server" as DB #F3E5F5

== Xem Lịch sử Đơn hàng ==

User -> Browser: Click "Đơn hàng của tôi"
Browser -> OrderCtrl: GET /orders\n?page=1&status=
activate OrderCtrl

OrderCtrl -> OrderSvc: getOrders(\ncustomerId, status, page)
activate OrderSvc
OrderSvc -> OrdDAO: findByCustomer(\ncustomerId, status, page)
activate OrdDAO
OrdDAO -> DB: SELECT o.*, e.title, e.bannerImage,\ne.startDate, e.location,\n(SELECT COUNT(*) FROM Tickets t\n WHERE t.orderId = o.orderId) as ticketCount\nFROM Orders o\nJOIN Events e ON o.eventId = e.eventId\nWHERE o.customerId = ?\nAND (o.status = ? OR ? IS NULL)\nORDER BY o.createdAt DESC\nOFFSET ? ROWS FETCH NEXT 10 ROWS ONLY
activate DB
DB --> OrdDAO: List<Order> + totalCount
deactivate DB
OrdDAO --> OrderSvc: orders
deactivate OrdDAO
OrderSvc --> OrderCtrl: orders, pagination
deactivate OrderSvc

OrderCtrl --> Browser: Forward → orders.jsp
deactivate OrderCtrl
Browser --> User: Danh sách đơn hàng:\n- Event name, date\n- Order code, total, status\n- Ticket count

== Xem Chi tiết Đơn hàng ==

User -> Browser: Click đơn hàng cụ thể
Browser -> OrderCtrl: GET /orders/detail\n?orderId={id}
activate OrderCtrl
OrderCtrl -> OrderSvc: getOrderDetail(\norderId, customerId)
activate OrderSvc
OrderSvc -> OrdDAO: findById(orderId)
activate OrdDAO
OrdDAO -> DB: SELECT o.*, e.*, v.code as voucherCode,\noi.*, tt.name as ticketTypeName\nFROM Orders o\nJOIN Events e ON ...\nLEFT JOIN Vouchers v ON o.voucherId=v.voucherId\nJOIN OrderItems oi ON o.orderId=oi.orderId\nJOIN TicketTypes tt ON oi.ticketTypeId=tt.ticketTypeId\nWHERE o.orderId=? AND o.customerId=?
activate DB
DB --> OrdDAO: Order + Items + Event
deactivate DB
OrdDAO --> OrderSvc: orderDetail
deactivate OrdDAO
OrderSvc --> OrderCtrl: orderDetail
deactivate OrderSvc
OrderCtrl --> Browser: Forward → order-detail.jsp
deactivate OrderCtrl
Browser --> User: Chi tiết đơn hàng:\n- Items breakdown\n- Voucher applied\n- Payment status & date

== Xem Vé của tôi ==

User -> Browser: Click "Vé của tôi"
Browser -> TktCtrl: GET /tickets
activate TktCtrl
TktCtrl -> TktSvc: getMyTickets(customerId)
activate TktSvc
TktSvc -> TktDAO: findByCustomer(customerId)
activate TktDAO
TktDAO -> DB: SELECT t.*, tt.name as typeName,\ntt.price, e.title, e.startDate,\ne.endDate, e.location,\ne.bannerImage, o.status as orderStatus,\nt.isCheckedIn, t.checkedInAt\nFROM Tickets t\nJOIN OrderItems oi ON t.orderItemId=oi.orderItemId\nJOIN TicketTypes tt ON oi.ticketTypeId=tt.ticketTypeId\nJOIN Orders o ON t.orderId=o.orderId\nJOIN Events e ON o.eventId=e.eventId\nWHERE o.customerId=?\nAND o.status='confirmed'\nORDER BY e.startDate
activate DB
DB --> TktDAO: List<Ticket>
deactivate DB
TktDAO --> TktSvc: tickets
deactivate TktDAO

TktSvc -> TktSvc: Group by event:\nupcoming vs past

TktSvc --> TktCtrl: groupedTickets
deactivate TktSvc
TktCtrl --> Browser: Forward → my-tickets.jsp
deactivate TktCtrl
Browser --> User: Vé của tôi:\n📅 Upcoming (sắp diễn ra)\n📋 Past (đã qua)

== Xem QR Code vé ==

User -> Browser: Click vào ticket card
Browser -> TktCtrl: GET /tickets/detail\n?ticketId={id}
activate TktCtrl
TktCtrl -> TktSvc: getTicketDetail(\nticketId, customerId)
activate TktSvc
TktSvc -> TktDAO: findById(ticketId)
activate TktDAO
TktDAO -> DB: SELECT * FROM Tickets t\nJOIN Orders o ON ...\nWHERE t.ticketId=?\nAND o.customerId=?
activate DB
DB --> TktDAO: Ticket
deactivate DB
TktDAO --> TktSvc: ticket
deactivate TktDAO
TktSvc --> TktCtrl: ticket
deactivate TktSvc
TktCtrl --> Browser: Forward → ticket-detail.jsp\n(QR code data for client render)
deactivate TktCtrl

Browser -> Browser: QRCode.js generates QR\nfrom ticket.qrCodeData\n(JWT signed payload)

Browser --> User: 🎟️ Ticket detail:\n- QR Code (large)\n- Ticket code: TKT-A1B2C3D4\n- Event name, date, location\n- Ticket type: VIP\n- Check-in status: ⏳ Chưa check-in

@enduml
