@startuml SD_01_Registration
' ============================================================
' SEQUENCE DIAGRAM - User Registration
' FR-01: Register new account → BCrypt → Session
' ============================================================

title **SD-01: User Registration\n(Sign Up → Session)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam maxmessagesize 200
skinparam sequence {
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1565C0
    ArrowColor #1565C0
}

actor "Guest" as User #LightGreen
participant "Browser\n(JSP)" as Browser #LightYellow
participant "AuthServlet\n(Controller)" as Auth #E3F2FD
participant "UserService" as Service #E8F5E9
participant "UserDAO" as DAO #FFF3E0
database "SQL Server" as DB #F3E5F5

== Step 1: Open Registration Page ==

User -> Browser: Click "Sign Up"
Browser -> Auth: GET /register
activate Auth
Auth --> Browser: Forward → register.jsp
deactivate Auth
Browser --> User: Display sign-up form

== Step 2: Submit Registration Form ==

User -> Browser: Fill in:\nfullName, email, password,\nconfirmPassword, phone
Browser -> Browser: **Client-side Validation:**\n- Required fields\n- Email format\n- Password ≥ 8 chars\n- password == confirmPassword\n- Phone format
Browser -> Auth: POST /register\n{fullName, email, password,\nconfirmPassword, phone}
activate Auth

== Step 3: Server-side Processing ==

Auth -> Auth: Parse + Validate input:\n- fullName not blank\n- valid email format\n- password ≥ 8 chars\n- password == confirmPassword

alt #FFE0E0 Validation Failed
    Auth --> Browser: Forward → register.jsp\n{error: "Password must be\nat least 8 characters"}\n+ preserve input
    Browser --> User: ❌ Display validation\nerror message
else #E8F5E9 Input Valid

    Auth -> Service: register(userData)
    activate Service

    ' --- Step 3a: Check Duplicate Email ---
    Service -> DAO: findByEmail(email)
    activate DAO
    DAO -> DB: SELECT * FROM Users\nWHERE email = ?\nAND isDeleted = 0
    activate DB
    DB --> DAO: User or null
    deactivate DB
    DAO --> Service: result
    deactivate DAO

    alt #FFE0E0 Email Already Exists
        Service --> Auth: throw "Email already registered"
        Auth --> Browser: Forward → register.jsp\n{error: "Email already in use"}\n+ preserve input
        Browser --> User: ❌ Email already exists
    else #E8F5E9 Email Available

        ' --- Step 3b: Hash Password ---
        Service -> Service: hashedPassword =\nBCrypt.hashpw(password,\nBCrypt.gensalt(12))

        ' --- Step 3c: Create User ---
        Service -> DAO: create(User)
        activate DAO
        DAO -> DB: INSERT INTO Users (\n  userId, email, password,\n  fullName, phone, role,\n  isActive, oauthUser,\n  oauthProvider, createdAt\n) VALUES (\n  NEWID(), ?, hashedPw,\n  ?, ?, 'customer',\n  1, 0, NULL, GETDATE()\n)
        activate DB
        DB --> DAO: userId (new)
        deactivate DB
        DAO --> Service: User (created)
        deactivate DAO

        Service --> Auth: User object
        deactivate Service

        ' --- Step 4: Create Session ---
        Auth -> Auth: session = request.getSession(true)\nsession.setAttribute("user", user)\nsession.setAttribute("role", role)

        Auth --> Browser: Redirect → / (homepage)\n+ flash: "Registration successful!"
        Browser --> User: ✅ Logged in,\nredirect to homepage
    end
end

deactivate Auth

@enduml
