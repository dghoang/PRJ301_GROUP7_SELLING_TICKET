@startuml SD_19_OrderExpiry
' ============================================================
' SEQUENCE DIAGRAM - Hết hạn Đơn hàng & Resume Payment
' FR-25: Order Expiry + Resume Payment
' ============================================================

title **SD-19: Hết hạn Đơn hàng & Thanh toán Lại\n(Order Expiry + Resume Payment)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #FFF3E0
    ParticipantBorderColor #E65100
    ArrowColor #E65100
}

actor "Attendee" as User #LightBlue
participant "Browser" as Browser #LightYellow
participant "OrderServlet" as OrderCtrl #FFF3E0
participant "PaymentServlet" as PayCtrl #FFF3E0
participant "OrderService" as OrderSvc #E8F5E9
participant "PaymentFactory" as Factory #FFF3E0
participant "SepayPaymentService" as SepaySvc #E8F5E9
participant "TicketTypeDAO" as TTDAO #FFF3E0
database "SQL Server" as DB #F3E5F5

== Scenario A: Đơn hàng hết hạn (Tự động) ==

note over OrderSvc, DB #FFFFCC
  **Scheduled Check (Application-level)**
  OrderExpiryFilter kiểm tra mỗi request
  hoặc Scheduled Task mỗi 1 phút
end note

OrderSvc -> DB: SELECT * FROM Orders\nWHERE status = 'pending'\nAND paymentExpiry < GETDATE()
activate DB
DB --> OrderSvc: List<ExpiredOrder>
deactivate DB

loop for each expired order
    OrderSvc -> DB: BEGIN TRANSACTION
    activate DB

    ' --- Cancel Order ---
    OrderSvc -> DB: UPDATE Orders SET\nstatus = 'expired',\ncancelledAt = GETDATE()\nWHERE orderId = ?

    ' --- Restore soldCount ---
    loop for each OrderItem
        OrderSvc -> DB: UPDATE TicketTypes SET\nsoldCount = soldCount - ?\nWHERE ticketTypeId = ?
    end

    ' --- Restore Voucher usage ---
    opt has voucher
        OrderSvc -> DB: UPDATE Vouchers SET\nusedCount = usedCount - 1\nWHERE voucherId = ?
    end

    OrderSvc -> DB: COMMIT
    deactivate DB

    OrderSvc -> DB: INSERT Notifications\n(userId, type='ORDER_EXPIRED',\nmessage='Đơn hàng {code}\nđã hết hạn thanh toán')
end

== Scenario B: Resume Payment (FR-25) ==

User -> Browser: Quay lại trang đơn hàng
Browser -> OrderCtrl: GET /orders
activate OrderCtrl
OrderCtrl --> Browser: Forward → orders.jsp\n(includes pending orders)
deactivate OrderCtrl
Browser --> User: Đơn hàng PENDING:\n"Chờ thanh toán (còn 8 phút)"

User -> Browser: Click "Thanh toán ngay"
Browser -> PayCtrl: GET /checkout/payment\n?orderId={orderId}
activate PayCtrl

PayCtrl -> OrderSvc: getOrder(orderId)
activate OrderSvc
OrderSvc -> DB: SELECT * FROM Orders\nWHERE orderId = ?\nAND customerId = ?
activate DB
DB --> OrderSvc: Order
deactivate DB
OrderSvc --> PayCtrl: Order
deactivate OrderSvc

alt #FFE0E0 Order expired
    PayCtrl --> Browser: Redirect → /orders\n+ "Đơn hàng đã hết hạn.\nVui lòng đặt lại."
    Browser --> User: ❌ Order expired
else #FFFDE7 Order expired but reorderable
    note over PayCtrl
      Tùy business rule:
      có thể cho phép tạo
      đơn hàng mới tự động
    end note
    PayCtrl --> Browser: Redirect → event page\n+ "Vui lòng đặt vé lại"
else #E8F5E9 Order still within payment window

    PayCtrl -> Factory: getProvider("sepay")
    PayCtrl -> SepaySvc: createPayment(order)
    activate SepaySvc
    SepaySvc -> SepaySvc: Regenerate QR Code\nwith SAME content:\n"ST" + order.orderCode\n(same reference for matching)
    SepaySvc --> PayCtrl: PaymentResult\n{qrUrl, bankInfo,\nremainingTime}
    deactivate SepaySvc

    PayCtrl --> Browser: Forward → payment.jsp\n(QR code, countdown = remaining)
    deactivate PayCtrl
    Browser --> User: Trang thanh toán:\nQR Code + Đếm ngược\n(thời gian còn lại)

    note over User, Browser
      Từ đây tiếp tục
      luồng SD-07 (SePay Payment)
    end note

end

@enduml
