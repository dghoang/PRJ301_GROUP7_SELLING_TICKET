left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontSize 11
skinparam handwritten false

skinparam usecase {
    BackgroundColor #FAFAFA
    BorderColor #546E7A
    FontSize 10
}
skinparam package {
    BackgroundColor #FFFFFF
    BorderColor #B0BEC5
    FontSize 11
    FontStyle bold
}
skinparam rectangle {
    RoundCorner 8
    BorderColor #1976D2
    BackgroundColor #FFFFFF
}

' ====== ACTORS (trái) ======
actor "Guest" as G #C8E6C9
actor "Customer" as C #BBDEFB
actor "Organizer" as O #FFE082
actor "Staff" as S #FFCDD2
actor "Admin" as A #CE93D8

G <|-- C

' ====== Sắp xếp actor theo chiều dọc ======
G -[hidden]d- C
C -[hidden]d- O
O -[hidden]d- S
S -[hidden]d- A

' ====== SYSTEM BOUNDARY ======
rectangle "SellingTicket Platform" {

    package "Truy cập công khai" as PKG1 {
        usecase "Đăng ký tài khoản" as UC11
        usecase "Đăng nhập" as UC12
