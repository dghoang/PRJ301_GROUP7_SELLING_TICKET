@startuml UC_09_SystemAdministration
' ============================================================
' USE CASE DIAGRAM - MODULE 9: Quản trị Hệ thống
' System Administration
' ============================================================

title **Biểu đồ Use Case - Module 9\nQuản trị Hệ thống**

left to right direction
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #EFEBE9
    BorderColor #4E342E
    FontSize 12
    ArrowColor #4E342E
}

' === ACTORS ===
actor "Admin\n(Quản trị viên)" as Admin #Orchid
actor "Organizer\n(Nhà tổ chức)" as Organizer #Gold

' === EXTERNAL ===
actor "Cloudinary\nCDN" as Cloudinary #LightGray

' === SYSTEM BOUNDARY ===
rectangle "Module 9: Quản trị Hệ thống" {

    usecase "**UC-9.1: Quản lý Users**\n---\nXem danh sách users.\nSearch, filter theo\nrole/status.\nActivate/Deactivate/\nDelete user." as UC_USER

    usecase "**UC-9.2: Quản lý Categories**\n---\nCRUD danh mục sự kiện:\nname, slug, description,\nicon. Toggle isActive." as UC_CAT

    usecase "**UC-9.3: Quản lý đơn hàng**\n---\nXem toàn bộ orders.\nFilter: status, event.\nConfirm payment thủ công.\nView order details." as UC_ORDER

    usecase "**UC-9.4: Quản lý thông báo**\n---\nGửi notification:\ntoàn hệ thống hoặc\ntargeted user groups." as UC_NOTIF

    usecase "**UC-9.5: Cấu hình hệ thống**\n---\nSite name, contact info,\ndefault max tickets/order,\npayment settings,\nplatform fee %." as UC_CONFIG

    usecase "**UC-9.6: Upload Media**\n---\nTải ảnh lên Cloudinary:\nevent banners,\nuser avatars,\ncategory icons." as UC_UPLOAD

    usecase "**UC-9.7: Quản lý Staff sự kiện**\n---\nOrganizer thêm/xóa staff.\nAssign staff từ\nregistered users.\nGán theo event." as UC_STAFF

    ' --- Sub use cases ---
    usecase "Ghi Activity Log\n(Admin actions)" as UC_LOG <<include>>

    usecase "Gửi Notification\ncho affected users" as UC_NOTIFY <<include>>

    usecase "Pagination &\nSearch/Filter" as UC_PAGINATE <<include>>

    usecase "Soft-delete\n(isDeleted = true)" as UC_SOFT_DEL <<include>>

    usecase "Bulk Operations\n(select multiple)" as UC_BULK <<extend>>
}

' === ASSOCIATIONS ===
Admin --> UC_USER
Admin --> UC_CAT
Admin --> UC_ORDER
Admin --> UC_NOTIF
Admin --> UC_CONFIG
Admin --> UC_UPLOAD

Organizer --> UC_UPLOAD
Organizer --> UC_STAFF

Cloudinary --> UC_UPLOAD

' === INCLUDE / EXTEND ===
UC_USER ..> UC_LOG : <<include>>
UC_USER ..> UC_PAGINATE : <<include>>
UC_USER ..> UC_SOFT_DEL : <<include>>
UC_USER ..> UC_NOTIFY : <<include>>

UC_CAT ..> UC_LOG : <<include>>
UC_ORDER ..> UC_PAGINATE : <<include>>
UC_ORDER ..> UC_LOG : <<include>>
UC_CONFIG ..> UC_LOG : <<include>>

UC_USER <.. UC_BULK : <<extend>>

' === NOTES ===
note right of UC_USER
  **FR-42**
  User management:
  - View all users (paginated)
  - Search by name/email
  - Filter by role/status
  - Ban/Unban users
  - Soft-delete (isDeleted)
end note

note right of UC_CONFIG
  **FR-46**
  SiteSettings (Singleton):
  - siteName
  - contactEmail
  - contactPhone
  - defaultMaxTickets
  - platformFeePercent
  - maintenanceMode
end note

note bottom of UC_STAFF
  **FR-48**
  Staff assignment:
  - Search users by email
  - Assign role per event
  - Remove staff
  - EventStaff(eventId,
    userId, role)
end note

@enduml
