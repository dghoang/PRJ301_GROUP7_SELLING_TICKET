@startuml UC_06_Communication
' ============================================================
' USE CASE DIAGRAM - MODULE 6: Chat & Giao tiếp
' Communication Management
' ============================================================

title **Biểu đồ Use Case - Module 6\nChat & Giao tiếp**

left to right direction
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #E0F7FA
    BorderColor #00838F
    FontSize 12
    ArrowColor #00838F
}

' === ACTORS ===
actor "Attendee\n(Người tham dự)" as Attendee #LightBlue
actor "Organizer\n(Nhà tổ chức)" as Organizer #Gold
actor "Admin\n(Quản trị viên)" as Admin #Orchid

' === SYSTEM BOUNDARY ===
rectangle "Module 6: Chat & Giao tiếp" {

    usecase "**UC-6.1: Tạo phiên chat**\n---\nAttendee mở cuộc hội thoại\nvới Organizer của sự kiện.\nTạo ChatSession mới\n(eventId, customerId,\norganizerId)." as UC_CHAT_NEW

    usecase "**UC-6.2: Gửi/Nhận tin nhắn**\n---\nGửi message trong session.\nHiển thị: senderName,\nsenderRole, timestamp.\nAJAX polling real-time." as UC_CHAT_MSG

    usecase "**UC-6.3: Gửi Support Ticket**\n---\nTạo ticket hỗ trợ.\nCategory: payment_error,\nmissing_ticket, cancellation,\nrefund, event_issue,\naccount_issue, technical,\nfeedback." as UC_SUPPORT_NEW

    usecase "**UC-6.4: Xử lý Support Ticket**\n---\nAdmin/Organizer xem,\ntrả lời, cập nhật status:\nopen → in_progress →\nresolved → closed." as UC_SUPPORT_PROC

    ' --- Sub use cases ---
    usecase "Auto-routing\nSupport Ticket\n(event-related → organizer,\nsystem → admin)" as UC_ROUTE <<include>>

    usecase "Auto-generate\nTicket Code\n(SUP-XXXXXX)" as UC_TICKETCODE <<include>>

    usecase "Gửi Notification\n(New message /\nticket update)" as UC_NOTIFY <<include>>

    usecase "Đính kèm\nEvent/Order\n(optional)" as UC_ATTACH <<extend>>

    usecase "Escalate Priority\n(normal → high → urgent)" as UC_ESCALATE <<extend>>
}

' === ASSOCIATIONS ===
Attendee --> UC_CHAT_NEW
Attendee --> UC_CHAT_MSG
Attendee --> UC_SUPPORT_NEW

Organizer --> UC_CHAT_MSG
Organizer --> UC_SUPPORT_NEW
Organizer --> UC_SUPPORT_PROC

Admin --> UC_SUPPORT_PROC

' === INCLUDE / EXTEND ===
UC_SUPPORT_NEW ..> UC_ROUTE : <<include>>
UC_SUPPORT_NEW ..> UC_TICKETCODE : <<include>>
UC_CHAT_MSG ..> UC_NOTIFY : <<include>>
UC_SUPPORT_PROC ..> UC_NOTIFY : <<include>>

UC_SUPPORT_NEW <.. UC_ATTACH : <<extend>>
UC_SUPPORT_PROC <.. UC_ESCALATE : <<extend>>

' === NOTES ===
note right of UC_CHAT_NEW
  **FR-29**
  1 ChatSession per
  (event, customer, organizer).
  Reopen if already exists.
end note

note right of UC_SUPPORT_NEW
  **FR-31**
  Auto-routing logic:
  if eventId != null AND
  category ∈ {missing_ticket,
  cancellation, event_issue}
  → "organizer"
  else → "admin"
end note

note bottom of UC_SUPPORT_PROC
  **FR-32**
  Status flow:
  open → in_progress
  → resolved → closed
  Admin can reopen.
end note

@enduml
