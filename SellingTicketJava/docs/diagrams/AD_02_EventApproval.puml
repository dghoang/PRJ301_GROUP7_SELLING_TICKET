@startuml AD_02_EventApproval
' ============================================================
' ACTIVITY DIAGRAM — Event Approval Flow
' Draft → Pending → Approved/Rejected → Resubmit
' ============================================================

title **Activity Diagram — Event Approval Flow\n(Luồng duyệt sự kiện)**

skinparam dpi 150
skinparam activity {
    BackgroundColor #E8EAF6
    BorderColor #283593
    ArrowColor #283593
    DiamondBackgroundColor #FFF3E0
}

|#E8EAF6|Organizer|
|#FFF3E0|System|
|#FCE4EC|Admin|

|Organizer|
start
:Tạo sự kiện mới\n(Nhập title, description, location,\ndate, banner, ticket types);

|System|
:Validate dữ liệu sự kiện;

if (Dữ liệu hợp lệ?) then (Không)
    |Organizer|
    :Hiển thị lỗi validation\n(thiếu trường bắt buộc,\nngày không hợp lệ);
    stop
else (Có)
endif

:CREATE Event\nstatus = **'draft'**;

|Organizer|
:Xem sự kiện (draft);
note right
  Organizer có thể chỉnh sửa
  toàn bộ thông tin khi ở trạng
  thái **draft** hoặc **rejected**
end note

if (Gửi duyệt?) then (Chưa)
    :Tiếp tục chỉnh sửa;
    stop
else (Gửi)
endif

|System|
:UPDATE Event SET\nstatus = **'pending'**;

:NotificationService → Admin\n"Sự kiện mới cần duyệt: {title}";

:ActivityLog.log("event_submitted",\neventId, organizerId);

|Admin|
:Nhận thông báo\nsự kiện chờ duyệt;
:Xem chi tiết sự kiện\n(title, mô tả, vé, banner);

if (Quyết định?) then #C8E6C9 (Approve)
    |System|
    :UPDATE Event SET\nstatus = **'approved'**;
    
    :NotificationService → Organizer\n"Sự kiện đã được duyệt!";
    
    :ActivityLog.log("event_approved",\neventId, adminId);
    
    |Organizer|
    :Nhận thông báo APPROVED;
    
    |System|
    :Sự kiện hiển thị công khai\ntrên trang chủ & tìm kiếm;
    
    if (Quá ngày kết thúc?) then (Có)
        :UPDATE Event SET\nstatus = **'completed'**;
        :Tổng kết doanh thu & thống kê;
    else (Chưa)
        :Sự kiện đang bán vé;
    endif
    
else #FFCDD2 (Reject)
    |Admin|
    :Nhập lý do từ chối\n(rejection_reason);
    
    |System|
    :UPDATE Event SET\nstatus = **'rejected'**,\nrejection_reason = "...",\nrejected_at = NOW();
    
    :NotificationService → Organizer\n"Sự kiện bị từ chối: {reason}";
    
    :ActivityLog.log("event_rejected",\neventId, adminId);
    
    |Organizer|
    :Nhận thông báo REJECTED\n+ Lý do từ chối;
    :Xem lý do & chỉnh sửa;
    
    if (Sửa & gửi lại?) then (Có)
        :Chỉnh sửa nội dung;
        |System|
        :UPDATE Event SET\nstatus = **'pending'**,\nrejection_reason = NULL;
        
        :NotificationService → Admin\n"Sự kiện được gửi lại: {title}";
        
        note right
          Vòng lặp duyệt lại
          (Admin review → Approve/Reject)
        end note
    else (Không)
        :Hủy sự kiện;
        |System|
        :UPDATE Event SET\nstatus = **'cancelled'**;
    endif
endif

stop

@enduml
