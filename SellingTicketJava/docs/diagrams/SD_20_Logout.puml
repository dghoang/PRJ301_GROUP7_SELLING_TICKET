@startuml SD_20_Logout
' ============================================================
' SEQUENCE DIAGRAM - Logout
' FR-06: Logout → Invalidate Session → Clear Cookie
' ============================================================

title **SD-20: Logout\n(Session Invalidation + Cookie Cleanup)**

skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam sequence {
    ParticipantBackgroundColor #E3F2FD
    ParticipantBorderColor #1565C0
    ArrowColor #1565C0
}

actor "Authenticated\nUser" as User #LightBlue
participant "Browser" as Browser #LightYellow
participant "AuthServlet\n(Controller)" as Auth #E3F2FD
participant "RefreshTokenDAO" as TokenDAO #FFF3E0
database "SQL Server" as DB #F3E5F5

== Logout Process ==

User -> Browser: Click "Logout"
Browser -> Auth: GET /logout
activate Auth

' --- Revoke Refresh Token ---
Auth -> Auth: Check cookie:\nst_refresh exists?

opt st_refresh Cookie Exists
    Auth -> TokenDAO: revokeByToken(tokenValue)
    activate TokenDAO
    TokenDAO -> DB: UPDATE RefreshTokens SET\nisRevoked = 1\nWHERE token = ?
    activate DB
    DB --> TokenDAO: Updated
    deactivate DB
    TokenDAO --> Auth: OK
    deactivate TokenDAO

    Auth -> Auth: Clear cookie:\nSet-Cookie: st_refresh=;\nPath=/; HttpOnly;\nMax-Age=0
end

' --- Activity Log ---
Auth -> DB: INSERT INTO ActivityLogs\n(userId, action='LOGOUT',\nipAddress, createdAt)

' --- Invalidate Session ---
Auth -> Auth: session.invalidate()

Auth --> Browser: Redirect → /login\n+ flash: "You have been\nlogged out successfully"
deactivate Auth

Browser --> User: ✅ Logged out\n→ Redirect to login page

@enduml
