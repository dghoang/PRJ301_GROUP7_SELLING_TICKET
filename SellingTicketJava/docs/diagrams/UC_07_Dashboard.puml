@startuml UC_07_Dashboard
' ============================================================
' USE CASE DIAGRAM - MODULE 7: Dashboard & Reporting
' KPI Dashboard + Charts for each role
' ============================================================

title **Use Case Diagram - Module 7\nDashboard & Reporting**

left to right direction
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #E8EAF6
    BorderColor #283593
    FontSize 12
    ArrowColor #283593
}

' === ACTORS ===
actor "Organizer" as Organizer #Gold
actor "Staff" as Staff #LightCoral
actor "Admin" as Admin #Orchid

' === SYSTEM BOUNDARY ===
rectangle "Module 7: Dashboard & Reporting" {

    usecase "**UC-7.1: Organizer Dashboard**\n---\nKPIs: total events, revenue,\ntickets sold.\nCharts: daily sales (30d),\ntop events revenue,\nticket type distribution." as UC_ORG

    usecase "**UC-7.2: Admin Dashboard**\n---\nSystem-wide stats:\nusers, events, orders,\ntotal revenue.\nCharts: monthly (12m),\ncategory distribution,\ntop organizers." as UC_ADMIN

    usecase "**UC-7.3: Staff Dashboard**\n---\nAssigned events list.\nCheck-in stats per event.\nQuick link to\ncheck-in page." as UC_STAFF

    usecase "**UC-7.4: Revenue Report**\n---\nOrganizer views\ndetailed revenue:\nby event, by date range.\nExport data." as UC_REVENUE
}

' === ASSOCIATIONS ===
Organizer --> UC_ORG
Organizer --> UC_REVENUE

Admin --> UC_ADMIN

Staff --> UC_STAFF

' === NOTES ===
note right of UC_ORG
  **FR-37**
  Organizer can only see
  their own events' data.
  Charts rendered with
  Chart.js library.
end note

note right of UC_ADMIN
  **FR-38**
  Admin sees system-wide data.
  Includes all organizers'
  combined revenue.
end note

note right of UC_STAFF
  **FR-39**
  Staff sees only events
  they're assigned to
  via EventStaff table.
end note

@enduml
