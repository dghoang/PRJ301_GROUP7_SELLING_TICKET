' ── Payment Subsystem (Strategy Pattern) ──────────

interface PaymentProvider #C8E6C9 {
    + initiate(order) : PaymentResult
    + verify(transactionId) : PaymentResult
    + getProviderName() : String
}

class PaymentFactory #C8E6C9 {
    {static} + getProvider(method) : PaymentProvider
}

class SeepayProvider #C8E6C9 {
    + initiate(order) : PaymentResult
    + verify(transactionId) : PaymentResult
    + generateQRContent(order) : String
    + getProviderName() : String
}

class BankTransferProvider #C8E6C9 {
    + initiate(order) : PaymentResult
    + verify(transactionId) : PaymentResult
    + getProviderName() : String
}

class PaymentResult #C8E6C9 {
    - success : boolean
    - transactionId : String
    - redirectUrl : String
    - qrContent : String
    - message : String
    - errorCode : String
}

PaymentProvider <|.. SeepayProvider
PaymentProvider <|.. BankTransferProvider
PaymentFactory --> PaymentProvider : creates
OrderService --> PaymentFactory : uses
SeepayProvider ..> PaymentResult : returns
BankTransferProvider ..> PaymentResult : returns

