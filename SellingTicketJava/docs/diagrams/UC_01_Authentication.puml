@startuml UC_01_Authentication
' ============================================================
' USE CASE DIAGRAM - MODULE 1: Authentication & User Management
' Authentication & Authorization
' ============================================================

title **Use Case Diagram - Module 1\nAuthentication & User Management**

left to right direction
skinparam actorStyle awesome
skinparam usecase {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 12
    ArrowColor #1565C0
}

' === ACTORS ===
actor "Guest\n(Unregistered)" as Guest #LightGreen
actor "Authenticated\nUser" as AuthUser #LightBlue
actor "Admin" as Admin #Orchid

' === EXTERNAL ===
actor "Google\nOAuth 2.0" as Google #Tomato

' === SYSTEM BOUNDARY ===
rectangle "Module 1: Authentication & User Management" {

    usecase "**UC-1.1: Register**\n---\nNew user creates account.\nInput: fullName, email,\npassword, phone.\nDefault role: customer." as UC_REG

    usecase "**UC-1.2: Login**\n---\nEmail + Password login.\nBCrypt verification.\nSession creation." as UC_LOGIN

    usecase "**UC-1.3: Google OAuth Login**\n---\nRedirect → Google\nCallback → find/create user\nSession creation.\noauthUser = true." as UC_OAUTH

    usecase "**UC-1.4: Manage Profile**\n---\nEdit fullName, phone,\ngender, dateOfBirth.\nUpload avatar\n(Cloudinary)." as UC_PROFILE

    usecase "**UC-1.5: Change Password**\n---\nVerify current password.\nNew password ≥ 8 chars.\nBCrypt hashing." as UC_CHANGEPW

    usecase "**UC-1.6: Logout**\n---\nSession invalidation.\nRevoke refresh token.\nClear cookie." as UC_LOGOUT

    ' --- Sub use cases ---
    usecase "Input Validation\n(Server-side)" as UC_VALIDATE <<include>>

    usecase "BCrypt\nHash/Verify" as UC_BCRYPT <<include>>

    usecase "Session\nManagement" as UC_SESSION <<include>>

    usecase "Remember Me\n(Refresh Token)" as UC_REMEMBER <<extend>>

    usecase "Rate Limiting\n(5 attempts/15min)" as UC_RATE <<include>>
}

' === ASSOCIATIONS ===
Guest --> UC_REG
Guest --> UC_LOGIN
Guest --> UC_OAUTH

AuthUser --> UC_PROFILE
AuthUser --> UC_CHANGEPW
AuthUser --> UC_LOGOUT

Admin --> UC_PROFILE

Google --> UC_OAUTH

' === INCLUDE / EXTEND ===
UC_REG ..> UC_VALIDATE : <<include>>
UC_REG ..> UC_BCRYPT : <<include>>
UC_LOGIN ..> UC_BCRYPT : <<include>>
UC_LOGIN ..> UC_SESSION : <<include>>
UC_LOGIN ..> UC_RATE : <<include>>
UC_OAUTH ..> UC_SESSION : <<include>>

UC_LOGIN <.. UC_REMEMBER : <<extend>>

' === NOTES ===
note right of UC_REG
  **FR-01**
  Password hashed with
  BCrypt(12 rounds).
  Auto-login after
  registration.
end note

note right of UC_LOGIN
  **FR-02**
  2-tier login rate limiting:
  1. email+IP: 5 fails → 15min lock
  2. IP only: 20 fails → 60min lock
end note

note right of UC_OAUTH
  **FR-03**
  Auto-create user if
  Google email doesn't exist.
  password = NULL for
  OAuth users.
end note

note bottom of UC_REMEMBER
  **FR-04**
  Refresh token stored
  in HttpOnly cookie.
  TTL: 30 days.
  Auto-revoke on logout.
end note

@enduml
