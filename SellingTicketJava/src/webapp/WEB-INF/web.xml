<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    
    <display-name>SellingTicketJava</display-name>
    
    <!-- ============================= -->
    <!-- SECURITY HEADERS FILTER       -->
    <!-- ============================= -->
    <filter>
        <filter-name>SecurityHeadersFilter</filter-name>
        <filter-class>com.sellingticket.filter.SecurityHeadersFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SecurityHeadersFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ============================= -->
    <!-- CSRF PROTECTION FILTER        -->
    <!-- ============================= -->
    <filter>
        <filter-name>CsrfFilter</filter-name>
        <filter-class>com.sellingticket.filter.CsrfFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/login</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/register</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/checkout</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/profile</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/change-password</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/organizer/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- ============================= -->
    <!-- AUTHORIZATION FILTER          -->
    <!-- ============================= -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.sellingticket.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/organizer/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/checkout</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/tickets</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/order-confirmation</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/profile</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/change-password</url-pattern>
    </filter-mapping>

    <!-- ============================= -->
    <!-- SESSION CONFIGURATION         -->
    <!-- ============================= -->
    <session-config>
        <session-timeout>60</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <!-- secure=true requires HTTPS — enable in production only -->
        </cookie-config>
    </session-config>

    <!-- ============================= -->
    <!-- WELCOME FILE                  -->
    <!-- ============================= -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ============================= -->
    <!-- ERROR PAGES                   -->
    <!-- ============================= -->
    <error-page>
        <error-code>404</error-code>
        <location>/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/500.jsp</location>
    </error-page>

</web-app>
