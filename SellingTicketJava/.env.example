# ===================================================
#  SellingTicket - Required Environment Variables
#  Copy this file to .env and fill in real values.
#  DO NOT commit .env to git!
# ===================================================

# JWT Secret - Used for signing all JWT tokens (access, refresh, ticket QR)
# Generate: openssl rand -base64 64
TICKETBOX_JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET

# Admin Private Key - Required for admin role upgrade endpoint
# Generate: openssl rand -hex 16
TICKETBOX_ADMIN_KEY=CHANGE_ME_TO_A_STRONG_KEY

# Database config (also in db.properties, env vars take priority)
# DB_SERVER=localhost
# DB_PORT=1433
# DB_NAME=SellingTicketDB
# DB_USER=sa
# DB_PASSWORD=your_password
